---
// src/components/Schedule.astro
const schedule = [
  {
    time: "13:00",
    title: "Rodinný oběd",
    description: "Nejprve nakrmíme rodinu.",
  },
  {
    time: "14:30",
    title: "Příprava na obřad",
    description: "Příchod a přivítání hostů.",
  },
  { time: "15:00", title: "Obřad" },
  { time: "15:30", title: "Oslava", description: "Až do konce!" },
  /* { time: "16:40", title: "Dort", description: "Čas na mlsání." },
  {
    time: "17:00",
    title: "Večerní raut",
    description: "Jídlo, pití a dobrá nálada.",
  },
  {
    time: "19:00",
    title: "První tanec",
    description: "A zahájení večerní party.",
  }, */
];
---

<section id="harmonogram" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <h2
    class="text-wedding-dark mb-24 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
  >
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >····</span
    >
    Harmonogram
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−−−−</span
    >
  </h2>

  <div class="relative mx-auto max-w-2xl">
    <!-- Vertical Line -->
    <div
      class="morse-line-vertical text-wedding-medium/30 absolute top-0 bottom-0 left-4 w-[2px] md:left-1/2 md:-translate-x-1/2"
    >
    </div>

    <div class="space-y-16">
      {
        schedule.map((item, index) => (
          <div
            class={`relative flex flex-col items-start md:flex-row ${index % 2 === 0 ? "md:flex-row-reverse" : ""}`}
          >
            {/* Timeline Marker (Alternating Dot and Dash) */}
            <div class="bg-wedding-light border-wedding-medium/50 absolute top-0 left-4 z-10 flex h-8 w-8 -translate-x-1/2 items-center justify-center rounded-full border md:left-1/2">
              {index % 2 === 0 ? (
                <div class="bg-wedding-dark h-1.5 w-1.5 rounded-full" />
              ) : (
                <div class="bg-wedding-dark h-1 w-3 rounded-sm" />
              )}
            </div>

            {/* Content */}
            <div
              class={`w-full pl-16 md:w-1/2 md:pl-0 ${index % 2 === 0 ? "md:pr-24 md:text-right" : "md:pl-24"}`}
            >
              <p class="text-wedding-medium mb-2 text-xs leading-none font-bold tracking-[0.3em] uppercase">
                {item.time}
              </p>
              <h3 class="text-wedding-dark mb-1 text-2xl font-bold">
                {item.title}
              </h3>
              <p class="text-wedding-dark text-base font-medium italic opacity-90">
                {item.description}
              </p>
            </div>
            {/* Spacer for the other side on desktop */}
            <div class="hidden md:block md:w-1/2" />
          </div>
        ))
      }
    </div>
  </div>

  <!-- <div class="mt-24 text-center">
    <p class="text-wedding-medium text-xs tracking-widest uppercase opacity-80">
      ⋅⋅∸⋅
    </p>
  </div> -->
</section>
