---
// src/components/Schedule.astro
import { getEntry } from "astro:content";

const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { schedule } = wedding.data;
---

<section id="harmonogram" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <div class="text-center">
    <h2
      class="text-wedding-dark animate-fade-in-up mb-24 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
    >
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 hover:opacity-100 md:text-3xl"
        data-decoded="H">····</span
      >
      {schedule.title}
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 hover:opacity-100 md:text-3xl"
        data-decoded="M">——</span
      >
    </h2>
  </div>

  <div class="animate-fade-in-up relative mx-auto max-w-2xl delay-100">
    <!-- Vertical Line -->
    <div
      class="morse-line-vertical text-wedding-medium/30 absolute top-0 bottom-0 left-4 w-[2px] md:left-1/2 md:-translate-x-1/2"
    >
    </div>

    <div class="space-y-16">
      {
        schedule.items.map((item, index) => (
          <div
            class={`group relative flex flex-col items-start md:flex-row ${index % 2 === 0 ? "md:flex-row-reverse" : ""}`}
          >
            {/* Timeline Marker (Alternating Dot and Dash) */}
            <div class="bg-wedding-light border-wedding-medium/50 group-hover:border-wedding-dark absolute top-0 left-4 z-10 flex h-8 w-8 -translate-x-1/2 items-center justify-center rounded-full border transition-all duration-300 group-hover:scale-110 md:left-1/2">
              {index % 2 === 0 ? (
                <div class="bg-wedding-dark h-1.5 w-1.5 rounded-full transition-transform duration-300 group-hover:scale-125" />
              ) : (
                <div class="bg-wedding-dark h-1 w-3 rounded-sm transition-transform duration-300 group-hover:scale-125" />
              )}
            </div>

            {/* Content */}
            <div
              class={`w-full pl-16 md:w-1/2 md:pl-0 ${index % 2 === 0 ? "md:pr-24 md:text-right" : "md:pl-24"}`}
            >
              <p class="text-wedding-medium mb-2 text-xs leading-none font-bold tracking-[0.3em] uppercase">
                {item.time}
              </p>
              <h3 class="text-wedding-dark mb-1 text-2xl font-bold">
                {item.title}
              </h3>
              <p class="text-wedding-dark text-base leading-relaxed font-medium opacity-85">
                {item.description}
              </p>
            </div>
            {/* Spacer for the other side on desktop */}
            <div class="hidden md:block md:w-1/2" />
          </div>
        ))
      }
    </div>
  </div>
</section>
