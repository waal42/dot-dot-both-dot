---
// src/components/Gifts.astro
import QRCode from "qrcode";
import { composeIBAN } from "ibantools";
import { getEntry } from "astro:content";
import morseMotif from "../assets/morse-motif.svg";

const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { gifts } = wedding.data;

// IBAN Generation Logic
const [accFull, bankCodeRaw] = gifts.accountNumber.split(" / ");
const [prefixPart, accPart] = accFull.includes("-")
  ? accFull.split("-")
  : ["", accFull];
const bankCode = bankCodeRaw.trim().padStart(4, "0");
const prefix = prefixPart.trim().padStart(6, "0");
const account = accPart.trim().padStart(10, "0");
const bban = bankCode + prefix + account;
const iban = composeIBAN({ countryCode: "CZ", bban });

// Generate static fallback QR Code for guests without JavaScript
const spayd = `SPD*1.0*ACC:${iban}*MSG:${gifts.qrMessage}`;
const qrCodeDataUrl = await QRCode.toDataURL(spayd, {
  margin: 2,
  width: 600,
  errorCorrectionLevel: "H",
  color: {
    dark: "#2d3a2d", // wedding-dark
    light: "#f1f3eb", // wedding-light
  },
});
---

<section id="dary" class="mx-auto max-w-4xl scroll-mt-24 px-6 py-24">
  <div class="text-center">
    <h2
      class="text-wedding-dark animate-fade-in-up mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
    >
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 hover:opacity-100 md:text-3xl"
        data-decoded="S">···</span
      >
      {gifts.title}
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 hover:opacity-100 md:text-3xl"
        data-decoded="Y">—·——</span
      >
    </h2>
  </div>

  <div
    id="gifts-container"
    data-account-number={gifts.accountNumber}
    data-iban={iban}
    data-qr-message={gifts.qrMessage}
    class="morse-border text-wedding-medium/30 bg-wedding-light animate-fade-in-up hover-card-premium shadow-sm delay-100"
  >
    <div class="px-8 py-16 text-center md:px-16 lg:px-24">
      {/* 1. Introductory Text */}
      <div class="mb-16 space-y-6">
        <p
          class="text-wedding-dark text-3xl leading-tight font-bold md:text-4xl"
        >
          {gifts.heading}
        </p>
        <p
          class="text-wedding-dark mx-auto max-w-2xl text-lg leading-relaxed font-medium opacity-90"
        >
          {gifts.description}
        </p>
      </div>

      <div class="morse-line text-wedding-medium/20 mx-auto mb-16 h-[2px] w-32">
      </div>

      {/* 2. Bank Account Details */}
      <div class="mb-16 space-y-4">
        <p
          class="text-wedding-medium text-xs font-bold tracking-[0.4em] uppercase opacity-70"
        >
          {gifts.accountLabel}
        </p>

        <div class="flex flex-col items-center justify-center gap-4">
          <p
            id="account-number"
            class="text-wedding-dark text-2xl font-bold tracking-[0.1em] sm:text-3xl md:text-4xl"
          >
            {gifts.accountNumber}
          </p>
          <button
            id="copy-btn"
            class="border-wedding-medium/40 text-wedding-medium hover:border-wedding-dark hover:text-wedding-dark hover:bg-wedding-dark/5 flex cursor-pointer items-center gap-2 rounded-sm border bg-transparent px-4 py-2 text-xs font-bold tracking-widest uppercase transition-all duration-300 active:scale-95"
            title="Kopírovat číslo účtu"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"
              ><rect width="14" height="14" x="8" y="8" rx="2" ry="2"
              ></rect><path
                d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"
              ></path></svg
            >
            <span id="copy-text">Kopírovat</span>
          </button>
        </div>

        <p
          class="text-wedding-medium mx-auto max-w-md pt-2 text-sm font-medium opacity-85"
        >
          {gifts.accountNote}
        </p>
      </div>

      <div class="morse-line text-wedding-medium/20 mx-auto mb-16 h-[2px] w-32">
      </div>

      {/* 3. Interactive Payment Calculator */}
      <div class="mb-16 space-y-6">
        <label
          for="gift-amount"
          class="text-wedding-medium block cursor-pointer text-xs font-bold tracking-[0.4em] uppercase opacity-70"
        >
          Zvolte výši příspěvku
        </label>

        {/* Currency Input Field */}
        <div class="relative mx-auto mb-6 max-w-xs">
          <input
            type="number"
            id="gift-amount"
            placeholder="Libovolná částka"
            class="border-wedding-medium/30 focus:border-wedding-dark text-wedding-dark w-full [appearance:textfield] border-b bg-transparent py-3 text-center text-2xl font-bold transition-colors outline-none [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
          />
          <div
            class="text-wedding-medium/60 absolute right-2 bottom-3 text-lg font-bold"
          >
            Kč
          </div>
        </div>
      </div>

      {/* 4. QR Code Section */}
      <div class="flex flex-col items-center">
        <div
          class="morse-border text-wedding-medium/30 bg-wedding-light relative mb-6 p-4 shadow-sm transition-transform duration-500 hover:scale-[1.02]"
        >
          <div
            class="relative flex h-56 w-56 items-center justify-center md:h-64 md:w-64"
          >
            {
              /* Dynamic interactive QR Code Image (Pre-rendered default on load) */
            }
            <img
              id="qr-image"
              src={qrCodeDataUrl}
              alt="QR platba"
              loading="lazy"
              class="h-full w-full"
            />
            {/* Center Motif Overlay */}
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="bg-wedding-light rounded-full shadow-md w-14 h-14 flex items-center justify-center border border-wedding-medium/20 overflow-hidden">
                <img
                  src={morseMotif.src}
                  alt="Morse motif badge"
                  class="w-full h-full object-contain scale-[1.5]"
                />
              </div>
            </div>
          </div>
        </div>
        <p
          class="text-wedding-medium text-xs font-bold tracking-[0.4em] uppercase opacity-60"
        >
          {gifts.qrLabel}
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import QRCode from "qrcode";

  const container = document.getElementById("gifts-container");
  const rawAccount = container?.getAttribute("data-account-number") || "";
  const iban = container?.getAttribute("data-iban") || "";
  const qrMessage = container?.getAttribute("data-qr-message") || "";

  const copyBtn = document.getElementById("copy-btn");
  const copyText = document.getElementById("copy-text");

  // Handle Copy Button
  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(rawAccount);
      if (copyText && copyBtn) {
        copyText.textContent = "Zkopírováno!";
        copyBtn.classList.add(
          "bg-wedding-dark",
          "text-wedding-light",
          "border-wedding-dark",
        );
        setTimeout(() => {
          copyText.textContent = "Kopírovat";
          copyBtn.classList.remove(
            "bg-wedding-dark",
            "text-wedding-light",
            "border-wedding-dark",
          );
        }, 2000);
      }
    } catch (err) {
      console.error("Failed to copy bank details: ", err);
    }
  });

  // Handle Dynamic QR Payment Calculation
  const qrImage = document.getElementById(
    "qr-image",
  ) as HTMLImageElement | null;
  const giftInput = document.getElementById(
    "gift-amount",
  ) as HTMLInputElement | null;

  const generateQRCode = async (amount: number | null) => {
    if (!qrImage) return;

    const parts = ["SPD*1.0", `ACC:${iban}`];
    if (amount && amount > 0) {
      parts.push(`AM:${amount.toFixed(2)}`);
      parts.push("CC:CZK");
    }
    if (qrMessage) {
      parts.push(`MSG:${qrMessage}`);
    }
    const spaydString = parts.join("*");

    try {
      const dataUrl = await QRCode.toDataURL(spaydString, {
        margin: 2,
        width: 600,
        errorCorrectionLevel: "H",
        color: {
          dark: "#2d3a2d", // wedding-dark
          light: "#f1f3eb", // wedding-light
        },
      });
      qrImage.src = dataUrl;
    } catch (err) {
      console.error("Failed to generate QR Code on client side: ", err);
    }
  };

  // Listen for text/number input changes
  giftInput?.addEventListener("input", (e) => {
    const val = parseFloat((e.target as HTMLInputElement).value);
    generateQRCode(isNaN(val) ? null : val);
  });

  // Initial draw
  generateQRCode(null);
</script>
