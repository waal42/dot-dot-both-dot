---
// src/components/Gifts.astro
import QRCode from "qrcode";
import { composeIBAN } from "ibantools";
import { weddingContent } from "../data/weddingContent";

const { gifts } = weddingContent;

// IBAN Generation Logic
const [accFull, bankCodeRaw] = gifts.accountNumber.split(" / ");
const [prefixPart, accPart] = accFull.includes("-")
  ? accFull.split("-")
  : ["", accFull];
const bankCode = bankCodeRaw.trim().padStart(4, "0");
const prefix = prefixPart.trim().padStart(6, "0");
const account = accPart.trim().padStart(10, "0");
const bban = bankCode + prefix + account;
const iban = composeIBAN({ countryCode: "CZ", bban });

// Generate QR Code for dynamic payment
const spayd = `SPD*1.0*ACC:${iban}*MSG:${gifts.qrMessage}`;
const qrCodeDataUrl = await QRCode.toDataURL(spayd, {
  margin: 2,
  width: 600,
  errorCorrectionLevel: "M",
  color: {
    dark: "#2d3a2d", // wedding-dark
    light: "#f1f3eb", // wedding-light
  },
});
---

<section id="dary" class="mx-auto max-w-4xl scroll-mt-24 px-6 py-24">
  <div class="text-center">
    <h2
      class="text-wedding-dark mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl animate-fade-in-up"
    >
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
        data-decoded="S"
        >···</span
      >
      {gifts.title}
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
        data-decoded="Y"
        >−·−−</span
      >
    </h2>
  </div>

  <div class="morse-border text-wedding-medium/30 bg-wedding-light shadow-sm animate-fade-in-up delay-100 hover-card-premium">
    <div class="px-8 py-16 text-center md:px-16 lg:px-24">
      {/* 1. Introductory Text */}
      <div class="mb-16 space-y-6">
        <p class="text-wedding-dark text-3xl font-bold md:text-4xl leading-tight">
          {gifts.heading}
        </p>
        <p
          class="text-wedding-dark mx-auto max-w-2xl text-lg leading-relaxed font-medium italic opacity-90"
        >
          {gifts.description}
        </p>
      </div>

      <div class="morse-line text-wedding-medium/20 mx-auto mb-16 h-[2px] w-32">
      </div>

      {/* 2. Bank Account Details */}
      <div class="mb-16 space-y-4">
        <p
          class="text-wedding-medium text-xs font-bold tracking-[0.4em] uppercase opacity-70"
        >
          {gifts.accountLabel}
        </p>
        
        <div class="flex flex-col items-center justify-center gap-4">
          <p
            id="account-number"
            class="text-wedding-dark text-2xl font-bold tracking-[0.1em] sm:text-3xl md:text-4xl"
          >
            {gifts.accountNumber}
          </p>
          <button
            id="copy-btn"
            class="border-wedding-medium/40 text-wedding-medium hover:border-wedding-dark hover:text-wedding-dark flex items-center gap-2 border bg-transparent px-4 py-2 text-xs font-bold tracking-widest uppercase transition-all duration-300 active:scale-95 cursor-pointer rounded-sm hover:bg-wedding-dark/5"
            title="Kopírovat číslo účtu"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            <span id="copy-text">Kopírovat</span>
          </button>
        </div>

        <p
          class="text-wedding-medium mx-auto max-w-md pt-2 text-sm font-medium italic opacity-85"
        >
          {gifts.accountNote}
        </p>
      </div>

      {/* 3. QR Code Section */}
      <div class="flex flex-col items-center">
        <div
          class="morse-border text-wedding-medium/20 bg-wedding-light relative mb-6 p-4 shadow-xl hover:scale-[1.02] transition-transform duration-500"
        >
          <div class="relative">
            <img
              src={qrCodeDataUrl}
              alt="QR platba"
              class="h-56 w-56 md:h-64 md:w-64"
            />
          </div>
        </div>
        <p
          class="text-wedding-medium text-xs font-bold tracking-[0.4em] uppercase opacity-60"
        >
          {gifts.qrLabel}
        </p>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ rawAccount: gifts.accountNumber }}>
  const copyBtn = document.getElementById("copy-btn");
  const copyText = document.getElementById("copy-text");

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(rawAccount);
      if (copyText && copyBtn) {
        copyText.textContent = "Zkopírováno!";
        copyBtn.classList.add("bg-wedding-dark", "text-wedding-light", "border-wedding-dark");
        setTimeout(() => {
          copyText.textContent = "Kopírovat";
          copyBtn.classList.remove("bg-wedding-dark", "text-wedding-light", "border-wedding-dark");
        }, 2000);
      }
    } catch (err) {
      console.error("Failed to copy bank details: ", err);
    }
  });
</script>
