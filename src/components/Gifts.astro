---
const giftInfo = {
  title: "Svatební dary",
  description: "Největším darem pro nás bude vaše přítomnost.",
  secondaryDescription:
    "Pokud byste nás přesto chtěli obdarovat, budeme vděční za příspěvek na naši svatební cestu nebo společné bydlení.",
  links: [
    { label: "Náš Dárkovník", url: "https://darkovnik.cz/vase-id", icon: "🎁" },
  ],
  accountNumber: "123456789 / 0100",
};
---

<section id="dary" class="mx-auto max-w-4xl scroll-mt-24 px-6 py-24">
  <h2
    class="mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
  >
    <span
      class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−··</span
    >
    {giftInfo.title}
    <span
      class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−·−−</span
    >
  </h2>

  <div
    class="border-wedding-gray/20 bg-wedding-white border p-12 text-center shadow-sm md:p-20"
  >
    <p class="mb-6 text-2xl font-bold">{giftInfo.description}</p>
    <p
      class="text-wedding-gray mx-auto mb-12 max-w-xl text-lg font-medium italic opacity-90"
    >
      {giftInfo.secondaryDescription}
    </p>

    <div class="flex flex-col items-center gap-8">
      <div class="space-y-2">
        <p
          class="text-wedding-gray text-xs font-bold tracking-[0.3em] uppercase opacity-80"
        >
          Číslo účtu
        </p>
        <p class="text-xl font-bold tracking-widest">
          {giftInfo.accountNumber}
        </p>
      </div>

      <div class="bg-wedding-gray/20 h-px w-12"></div>

      {
        giftInfo.links.map((link) => (
          <a
            href={link.url}
            target="_blank"
            class="text-wedding-black border-wedding-black hover:bg-wedding-black hover:text-wedding-white group inline-flex items-center gap-3 border bg-transparent px-10 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-300"
          >
            <span>{link.icon}</span>
            {link.label}
            <span class="text-wedding-gray group-hover:text-wedding-white ml-2 opacity-30 transition-all group-hover:opacity-60">
              ··
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
