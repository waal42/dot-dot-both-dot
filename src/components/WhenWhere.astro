---
// src/components/WhenWhere.astro
import { getEntry } from "astro:content";

const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { whenWhere } = wedding.data;
const { venueName, address, coords, googleMapsUrl, description, transportOptions, calendar } = whenWhere;

// Generate .ics standard iCalendar files & Google Calendar links dynamically
const generateIcsDataUri = (eventConfig: { uid: string; start: string; end: string }) => {
  const icsLines = [
    "BEGIN:VCALENDAR",
    "VERSION:2.0",
    `PRODID:${calendar.prodId}`,
    "BEGIN:VEVENT",
    `UID:${eventConfig.uid}`,
    "DTSTAMP:20260530T000000Z",
    `DTSTART:${eventConfig.start}`,
    `DTEND:${eventConfig.end}`,
    `SUMMARY:${calendar.summary}`,
    `DESCRIPTION:${calendar.description}`,
    `LOCATION:${calendar.location}`,
    "END:VEVENT",
    "END:VCALENDAR"
  ];
  return `data:text/calendar;charset=utf8,${encodeURIComponent(icsLines.join("\r\n"))}`;
};

const generateGoogleUrl = (eventConfig: { start: string; end: string }) => {
  const baseUrl = "https://calendar.google.com/calendar/render?action=TEMPLATE";
  const params = new URLSearchParams({
    text: calendar.summary,
    dates: `${eventConfig.start}/${eventConfig.end}`,
    details: calendar.description,
    location: calendar.location,
  });
  return `${baseUrl}&${params.toString()}`;
};

const familyIcsDataUri = generateIcsDataUri(calendar.family);
const familyGoogleUrl = generateGoogleUrl(calendar.family);

const guestIcsDataUri = generateIcsDataUri(calendar.guest);
const guestGoogleUrl = generateGoogleUrl(calendar.guest);
---

<section id="kdy-a-kde" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <h2
    class="text-wedding-dark mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl animate-fade-in-up"
  >
    <span
      class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
      data-decoded="K"
      >−·−</span
    >
    {whenWhere.title}
    <span
      class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
      data-decoded="E"
      >·</span
    >
  </h2>

  <div class="grid items-stretch gap-12 lg:grid-cols-5 animate-fade-in-up delay-100">
    <!-- Venue Info, Calendar & Transport Info (Side Column) -->
    <div class="flex flex-col justify-between space-y-10 lg:col-span-2">
      
      <!-- WHEN SECTION (Kdy se potkáme) -->
      <div class="text-center lg:text-left space-y-4">
        <p class="text-wedding-medium text-xs font-bold tracking-[0.4em] uppercase">
          Kdy se potkáme?
        </p>
        <div class="flex flex-col sm:flex-row items-center gap-6 justify-center lg:justify-start">
          <!-- Calendar Card Graphic -->
          <div class="bg-wedding-dark text-wedding-light p-4 shadow-md rounded-sm w-28 text-center flex flex-col justify-center border border-wedding-medium/20 hover-card-premium shrink-0 select-none">
            <span class="text-xs uppercase tracking-widest opacity-80 font-bold">Srpen</span>
            <span class="text-4xl font-extrabold my-1 leading-none">15</span>
            <span class="text-[10px] uppercase tracking-wider font-semibold opacity-75">Sobota</span>
          </div>
          
          <div class="text-center lg:text-left space-y-4">
            <p class="text-wedding-dark text-2xl font-bold tracking-tight">Sobota, 15. srpna 2026</p>
            
            <div class="space-y-4 pt-1 text-center lg:text-left">
              <div class="space-y-1">
                <p class="text-wedding-dark text-xs font-bold uppercase tracking-wider opacity-85">Pro rodinu (oběd od 13:00)</p>
                <div class="flex items-center justify-center lg:justify-start gap-3">
                  <a 
                    href={familyGoogleUrl} 
                    target="_blank" 
                    class="text-[10px] font-bold tracking-widest uppercase text-wedding-dark border-b border-wedding-dark/30 hover:border-wedding-dark pb-0.5 transition-colors cursor-pointer select-none"
                  >
                    + Google Kalendář
                  </a>
                  <span class="text-wedding-medium/40 text-xs select-none">•</span>
                  <a 
                    href={familyIcsDataUri} 
                    download="svatba-rodina.ics" 
                    class="text-[10px] font-bold tracking-widest uppercase text-wedding-dark border-b border-wedding-dark/30 hover:border-wedding-dark pb-0.5 transition-colors cursor-pointer select-none"
                  >
                    + Pozvánka (.ics)
                  </a>
                </div>
              </div>
              
              <div class="space-y-1 pt-1">
                <p class="text-wedding-dark text-xs font-bold uppercase tracking-wider opacity-85">Pro ostatní hosty (od 14:30)</p>
                <div class="flex items-center justify-center lg:justify-start gap-3">
                  <a 
                    href={guestGoogleUrl} 
                    target="_blank" 
                    class="text-[10px] font-bold tracking-widest uppercase text-wedding-dark border-b border-wedding-dark/30 hover:border-wedding-dark pb-0.5 transition-colors cursor-pointer select-none"
                  >
                    + Google Kalendář
                  </a>
                  <span class="text-wedding-medium/40 text-xs select-none">•</span>
                  <a 
                    href={guestIcsDataUri} 
                    download="svatba-hoste.ics" 
                    class="text-[10px] font-bold tracking-widest uppercase text-wedding-dark border-b border-wedding-dark/30 hover:border-wedding-dark pb-0.5 transition-colors cursor-pointer select-none"
                  >
                    + Pozvánka (.ics)
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Divider line -->
      <div class="morse-line text-wedding-medium/20 mx-auto h-[2px] w-full max-w-md lg:mx-0"></div>

      <!-- WHERE SECTION (Kde) -->
      <div class="text-center lg:text-left space-y-6">
        <div>
          <p
            class="text-wedding-medium mb-3 text-xs font-bold tracking-[0.4em] uppercase"
          >
            Místo konání
          </p>
          <h3 class="mb-3 text-4xl font-bold tracking-tight md:text-5xl text-wedding-dark leading-tight">
            {venueName}
          </h3>
          <p class="text-wedding-medium text-lg font-medium italic">
            {address}
          </p>
        </div>

        <p
          class="text-wedding-dark mx-auto text-base leading-relaxed lg:mx-0 opacity-90 font-medium italic text-justify lg:text-left"
        >
          {description}
        </p>
        
        <div class="pt-2 flex justify-center lg:justify-start">
          <a
            href={googleMapsUrl}
            target="_blank"
            class="morse-border text-wedding-dark border-wedding-dark hover:bg-wedding-dark hover:text-wedding-light inline-flex justify-center items-center gap-3 bg-transparent px-8 py-3.5 text-xs font-bold tracking-widest uppercase transition-all duration-300 hover:scale-105 active:scale-95 shadow-sm select-none cursor-pointer"
          >
            Navigovat
          </a>
        </div>
      </div>

      <!-- Transportation Selector -->
      <div class="space-y-6 pt-6">
        <p class="text-wedding-medium text-center lg:text-left text-xs font-bold tracking-[0.4em] uppercase">
          Jak se k nám dostanete?
        </p>
        
        <!-- Tabs Grid -->
        <div class="bg-wedding-light border-wedding-medium/20 flex gap-1 border p-1 shadow-sm rounded-sm">
          {
            transportOptions.map((opt, idx) => (
              <button
                data-tab={opt.id}
                class={`transport-tab flex-1 px-3 py-3 text-[10px] sm:text-xs font-bold tracking-wider uppercase transition-all duration-300 cursor-pointer text-center rounded-sm select-none ${idx === 0 ? "bg-wedding-dark text-wedding-light" : "text-wedding-dark/60 hover:bg-wedding-medium/10"}`}
              >
                {opt.label}
              </button>
            ))
          }
        </div>

        <!-- Detail Panels (Stacked dynamically) -->
        <div class="relative min-h-[140px]">
          {
            transportOptions.map((opt, idx) => (
              <div
                id={`panel-${opt.id}`}
                class={`transport-panel bg-wedding-light/40 border border-wedding-medium/20 p-6 shadow-sm rounded-sm transition-all duration-500 ${idx === 0 ? "translate-y-0 opacity-100" : "pointer-events-none hidden translate-y-4 opacity-0"}`}
              >
                <p class="text-wedding-medium mb-2 text-[10px] font-bold tracking-[0.3em] uppercase">
                  <span class="morse-decoder" data-decoded={opt.morseText}>
                    {opt.morse}
                  </span>
                </p>
                <h4 class="text-wedding-dark mb-2 text-lg font-bold leading-tight">
                  {opt.title}
                </h4>
                <p class="text-wedding-dark text-sm leading-relaxed font-medium italic opacity-95">
                  {opt.detail}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Clean Map Container (No clutter overlays, full visibility!) -->
    <div
      class="morse-border text-wedding-medium/30 bg-wedding-light relative h-[450px] lg:h-auto overflow-hidden shadow-sm lg:col-span-3 min-h-[450px] lg:min-h-[550px]"
    >
      <!-- Map Element -->
      <div
        id="map"
        class="z-0 h-full w-full grayscale transition-all duration-700 hover:grayscale-0"
      >
      </div>
    </div>
  </div>
</section>

<!-- Leaflet.js Assets -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  crossorigin=""
/>
<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  crossorigin=""></script>

<script is:inline define:vars={{ venue: { name: venueName, address, coords, googleMapsUrl }, transportOptions }}>
  document.addEventListener("DOMContentLoaded", () => {
    const map = L.map("map", {
      center: venue.coords,
      zoom: 16,
      scrollWheelZoom: false,
      zoomControl: false, // Cleaner look
    });

    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution: "&copy; OpenStreetMap",
      },
    ).addTo(map);

    const icons = {
      ring: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 6V2"/><path d="m10 2 2 2 2-2"/></svg>`,
      train: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3.1V7a4 4 0 0 0 8 0V3.1"/><path d="m9 15-1-1"/><path d="m15 15 1-1"/><path d="M9 19c-2.8 0-5-2.2-5-5v-4a8 8 0 0 1 16 0v4c0 2.8-2.2 5-5 5Z"/><path d="m8 19-2 3"/><path d="m16 19 2 3"/></svg>`,
      parking: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>`,
      bus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="3" rx="2"/><path d="M4 11h16"/><path d="M8 15h.01"/><path d="M16 15h.01"/><path d="M6 19v2"/><path d="M18 19v2"/></svg>`,
    };

    const createCustomIcon = (type, isWedding = false) => {
      const size = isWedding ? 40 : 32;
      const color = isWedding ? "#2d3a2d" : "#9a91a4";
      return L.divIcon({
        className: "custom-map-icon",
        html: `<div style="background-color: white; width: ${size}px; height: ${size}px; border: 2px solid ${color}; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px -4px rgb(0 0 0 / 0.1); color: ${color}; padding: 6px;">${icons[type] || ""}</div>`,
        iconSize: [size, size],
        iconAnchor: [size / 2, size / 2],
      });
    };

    const markers = {};
    L.marker(venue.coords, { icon: createCustomIcon("ring", true) })
      .addTo(map)
      .bindPopup(`<b>${venue.name}</b>`);

    transportOptions.forEach((opt) => {
      markers[opt.id] = L.marker(opt.marker.coords, {
        icon: createCustomIcon(opt.marker.icon),
      }).bindPopup(`<b>${opt.marker.title}</b>`);
    });

    markers["car"].addTo(map);

    const tabs = document.querySelectorAll(".transport-tab");
    const panels = document.querySelectorAll(".transport-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.getAttribute("data-tab");

        tabs.forEach((t) =>
          t.classList.remove("bg-wedding-dark", "text-wedding-light"),
        );
        tabs.forEach((t) => t.classList.add("text-wedding-dark/60"));
        tab.classList.add("bg-wedding-dark", "text-wedding-light");
        tab.classList.remove("text-wedding-dark/60");

        panels.forEach((p) => {
          p.classList.add("hidden", "opacity-0", "translate-y-4", "pointer-events-none");
          p.classList.remove("opacity-100", "translate-y-0");
        });

        const activePanel = document.getElementById(`panel-${target}`);
        if (activePanel) {
          activePanel.classList.remove("hidden", "pointer-events-none");
          // Trigger reflow for animation
          setTimeout(() => {
            activePanel.classList.add("opacity-100", "translate-y-0");
            activePanel.classList.remove("opacity-0", "translate-y-4");
          }, 10);
        }

        Object.values(markers).forEach((m) => map.removeLayer(m));
        if (markers[target]) {
          markers[target].addTo(map);
          const group = L.featureGroup([
            L.marker(venue.coords),
            markers[target],
          ]);
          map.fitBounds(group.getBounds().pad(0.5));
        }
      });
    });

    setTimeout(() => map.invalidateSize(), 100);
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 0 !important;
    border: 1px solid #9a91a433;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1) !important;
  }
  .leaflet-popup-tip {
    display: none;
  }
  .custom-map-icon {
    background: none !important;
    border: none !important;
  }
</style>
