---
const venue = {
  name: "Sokec, Šlapanice",
  address: "Smetanova 405, 664 51 Šlapanice",
  coords: [49.163212, 16.726418],
  googleMapsUrl: "https://maps.app.goo.gl/AJ5MkMekiaeEhSGf6",
};

const locations = [
  {
    label: "Místo konání",
    value: venue.name,
    detail: venue.address,
    type: "venue",
  },
  {
    label: "Doprava & Parkování",
    value: "Vlakem i autem",
    detail: "Vlakem (S2) z Brna, autem parkování u Sokecu.",
    type: "transport",
  },
];

// Custom markers for the map
const mapMarkers = [
  {
    coords: venue.coords,
    title: "Sokec (Místo obřadu a oslavy)",
    type: "wedding",
    icon: "ring",
  },
  {
    coords: [49.16432, 16.72485],
    title: "Vlaková stanice Šlapanice",
    type: "train",
    icon: "train",
  },
  {
    coords: [49.1625, 16.7275],
    title: "Parkoviště u Sokecu",
    type: "parking",
    icon: "parking",
  },
];
---

<section id="kdy-a-kde" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <h2
    class="mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
  >
    <span
      class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−·−</span
    >
    Kdy a kde
    <span
      class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−−·−</span
    >
  </h2>

  <div class="grid items-stretch gap-8 lg:grid-cols-5">
    <!-- Text Info -->
    <div class="flex flex-col gap-4 lg:col-span-2">
      {
        locations.map((item) => (
          <div class="bg-wedding-white border-wedding-gray/20 flex flex-1 flex-col items-center justify-center border p-10 text-center shadow-sm">
            <p class="text-wedding-gray mb-4 text-[10px] font-bold tracking-[0.4em] uppercase">
              {item.label}
            </p>
            <p class="mb-2 text-2xl font-bold">{item.value}</p>
            <p class="text-wedding-gray text-sm font-medium italic opacity-90">
              {item.detail}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Custom Map Container -->
    <div
      class="border-wedding-gray/20 bg-wedding-white group relative h-112.5 border p-4 shadow-sm lg:col-span-3"
    >
      <div
        id="map"
        class="z-10 h-full w-full grayscale transition-all duration-700 hover:grayscale-0"
      >
      </div>
      <div
        class="bg-wedding-white absolute inset-0 z-0 flex items-center justify-center"
      >
        <p
          class="text-wedding-gray text-xs tracking-widest uppercase opacity-40"
        >
          Načítám mapu...
        </p>
      </div>
    </div>
  </div>

  <div class="mt-16 text-center">
    <a
      href={venue.googleMapsUrl}
      target="_blank"
      class="text-wedding-black border-wedding-black hover:bg-wedding-black hover:text-wedding-white group inline-flex items-center gap-6 border bg-transparent px-12 py-5 text-sm font-bold tracking-widest uppercase transition-all duration-300"
    >
      <span
        class="text-wedding-gray group-hover:text-wedding-white opacity-30 transition-all group-hover:opacity-60"
        >·−</span
      >
      Navigovat k místu
      <span
        class="text-wedding-gray group-hover:text-wedding-white opacity-30 transition-all group-hover:opacity-60"
        >−·</span
      >
    </a>
  </div>
</section>

<!-- Leaflet.js Assets -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>
<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
  crossorigin=""></script>

<script is:inline define:vars={{ venue, mapMarkers }}>
  // We use is:inline to ensure Leaflet is available when script runs
  document.addEventListener("DOMContentLoaded", () => {
    const map = L.map("map", {
      center: venue.coords,
      zoom: 16,
      scrollWheelZoom: false,
    });

    // Use a clean, minimal map style (CartoDB Positron)
    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution: "&copy; OpenStreetMap",
      },
    ).addTo(map);

    // SVG Icons
    const icons = {
      ring: `
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-ring"><path d="M12 22a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 6V2"/><path d="m10 2 2 2 2-2"/></svg>
            `,
      train: `
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-train-front"><path d="M8 3.1V7a4 4 0 0 0 8 0V3.1"/><path d="m9 15-1-1"/><path d="m15 15 1-1"/><path d="M9 19c-2.8 0-5-2.2-5-5v-4a8 8 0 0 1 16 0v4c0 2.8-2.2 5-5 5Z"/><path d="m8 19-2 3"/><path d="m16 19 2 3"/></svg>
            `,
      parking: `
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-square-parking"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>
            `,
    };

    const createCustomIcon = (type, isWedding = false) => {
      const size = isWedding ? 40 : 32;
      const color = isWedding ? "#000" : "#5a544e";
      const iconSvg = icons[type] || "";

      return L.divIcon({
        className: "custom-map-icon",
        html: `
                    <div style="
                        background-color: white;
                        width: ${size}px;
                        height: ${size}px;
                        border: 2px solid ${color};
                        border-radius: 50%;
                        display: flex;
                        items-center;
                        justify-content: center;
                        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
                        color: ${color};
                        padding: 6px;
                    ">
                        ${iconSvg}
                    </div>
                `,
        iconSize: [size, size],
        iconAnchor: [size / 2, size / 2],
        popupAnchor: [0, -size / 2],
      });
    };

    // Add Markers
    mapMarkers.forEach((m) => {
      const icon = createCustomIcon(m.icon, m.type === "wedding");
      L.marker(m.coords, { icon })
        .addTo(map)
        .bindPopup(
          `<b style="font-family: sans-serif; font-size: 14px;">${m.title}</b>`,
        );
    });

    // Force a resize fix for hidden elements
    setTimeout(() => map.invalidateSize(), 100);
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 0 !important;
    border: 1px solid #5a544e33;
    box-shadow: none !important;
  }
  .leaflet-popup-tip {
    display: none;
  }
</style>
