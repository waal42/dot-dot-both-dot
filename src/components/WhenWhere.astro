---
const venue = {
  name: "Sokec, Šlapanice",
  address: "Nádražní 87, 664 51 Šlapanice",
  coords: [49.1605206, 16.7286136],
  googleMapsUrl: "https://maps.app.goo.gl/AJ5MkMekiaeEhSGf6",
};

const transportOptions = [
  {
    id: "car",
    label: "Autem",
    icon: "car",
    morse: "·−·−·−·−·−·−·−·−",
    title: "Doprava autem",
    detail: "Parkování přímo u Sokecu nebo v přilehlých ulicích.",
    marker: {
      coords: [49.1594822, 16.7289861],
      title: "Parkoviště u Sokecu",
      icon: "parking",
    },
  },
  {
    id: "train",
    label: "Vlakem",
    icon: "train",
    morse: "···−···−···−···−",
    title: "Vlakem (S6)",
    detail: "Z Brna (S6) na stanici Šlapanice, poté 5 min chůze.",
    marker: {
      coords: [49.1567917, 16.7294883],
      title: "Vlaková stanice Šlapanice",
      icon: "train",
    },
  },
  {
    id: "bus",
    label: "Trolejbusem",
    icon: "bus",
    morse: "----------------",
    title: "Trolejbusem (31)",
    detail: "Linka 31 z Hlavního nádraží na zastávku 'Šlapanice Kalvodova'.",
    marker: {
      coords: [49.1664506, 16.7262975],
      title: "Zastávka Šlapanice Kalvodova",
      icon: "bus",
    },
  },
];
---

<section id="kdy-a-kde" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <h2
    class="text-wedding-dark mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
  >
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−·−</span
    >
    Kdy a kde
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−−·−</span
    >
  </h2>

  <div class="grid items-stretch gap-12 lg:grid-cols-5">
    <!-- Venue Info (Side Column) -->
    <div class="flex flex-col justify-center space-y-12 lg:col-span-2">
      <div class="text-center lg:text-left">
        <p
          class="text-wedding-medium mb-4 text-xs font-bold tracking-[0.4em] uppercase"
        >
          Místo konání
        </p>
        <h3 class="mb-4 text-5xl font-bold tracking-tight md:text-6xl">
          {venue.name}
        </h3>
        <p class="text-wedding-dark mb-8 text-2xl font-medium italic">
          {venue.address}
        </p>

        <div
          class="morse-line text-wedding-medium/30 mx-auto mb-8 h-[2px] w-24 lg:mx-0"
        >
        </div>

        <p
          class="text-wedding-dark mx-auto max-w-sm text-base leading-relaxed lg:mx-0"
        >
          Sokec je taková fajn restaurace pod Sokolovnou, před kterou je dobrej
          plácek na párty a sestra už tam svatbu měla a bylo to fajn.
        </p>
      </div>

      <div class="hidden lg:block">
        <a
          href={venue.googleMapsUrl}
          target="_blank"
          class="text-wedding-dark border-wedding-dark hover:bg-wedding-dark hover:text-wedding-light group inline-flex items-center gap-6 border bg-transparent px-10 py-4 text-sm font-bold tracking-widest uppercase transition-all duration-300"
        >
          Navigovat
          <span
            class="text-wedding-medium group-hover:text-wedding-light opacity-30"
            >·−−</span
          >
        </a>
      </div>
    </div>

    <!-- Integrated Map Container -->
    <div
      class="morse-border text-wedding-medium/40 bg-wedding-light relative h-[500px] overflow-hidden shadow-xl lg:col-span-3"
    >
      <!-- Map Element -->
      <div
        id="map"
        class="z-0 h-full w-full grayscale transition-all duration-700 hover:grayscale-0"
      >
      </div>

      <!-- Floating Tabs (Top) -->
      <div class="absolute top-6 left-1/2 z-10 w-auto -translate-x-1/2 px-4">
        <div
          class="bg-wedding-light/90 border-wedding-medium/20 flex gap-1 border p-1 shadow-lg backdrop-blur-sm"
        >
          {
            transportOptions.map((opt, idx) => (
              <button
                data-tab={opt.id}
                class={`transport-tab px-6 py-3 text-xs font-bold tracking-widest uppercase transition-all duration-300 ${idx === 0 ? "bg-wedding-dark text-wedding-light" : "text-wedding-dark/60 hover:bg-wedding-medium/10"}`}
              >
                {opt.label}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Floating Info Panel (Bottom) -->
      <div class="absolute right-6 bottom-6 left-6 z-10 md:right-auto md:w-96">
        {
          transportOptions.map((opt, idx) => (
            <div
              id={`panel-${opt.id}`}
              class={`transport-panel bg-wedding-light/95 border-wedding-medium/30 border p-8 shadow-2xl backdrop-blur-sm transition-all duration-500 ${idx === 0 ? "translate-y-0 opacity-100" : "pointer-events-none hidden translate-y-4 opacity-0"}`}
            >
              <p class="text-wedding-medium mb-3 text-xs font-bold tracking-[0.3em] uppercase">
                {opt.morse}
              </p>
              <h4 class="text-wedding-dark mb-2 text-xl font-bold">
                {opt.title}
              </h4>
              <p class="text-wedding-dark text-sm leading-relaxed font-medium italic">
                {opt.detail}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!-- Leaflet.js Assets -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  crossorigin=""
/>
<script
  is:inline
  src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
  crossorigin=""></script>

<script is:inline define:vars={{ venue, transportOptions }}>
  document.addEventListener("DOMContentLoaded", () => {
    const map = L.map("map", {
      center: venue.coords,
      zoom: 16,
      scrollWheelZoom: false,
      zoomControl: false, // Cleaner look
    });

    L.tileLayer(
      "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      {
        attribution: "&copy; OpenStreetMap",
      },
    ).addTo(map);

    const icons = {
      ring: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z"/><path d="M12 6V2"/><path d="m10 2 2 2 2-2"/></svg>`,
      train: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3.1V7a4 4 0 0 0 8 0V3.1"/><path d="m9 15-1-1"/><path d="m15 15 1-1"/><path d="M9 19c-2.8 0-5-2.2-5-5v-4a8 8 0 0 1 16 0v4c0 2.8-2.2 5-5 5Z"/><path d="m8 19-2 3"/><path d="m16 19 2 3"/></svg>`,
      parking: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/></svg>`,
      bus: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="16" x="4" y="3" rx="2"/><path d="M4 11h16"/><path d="M8 15h.01"/><path d="M16 15h.01"/><path d="M6 19v2"/><path d="M18 19v2"/></svg>`,
    };

    const createCustomIcon = (type, isWedding = false) => {
      const size = isWedding ? 40 : 32;
      const color = isWedding ? "#2d3a2d" : "#9a91a4";
      return L.divIcon({
        className: "custom-map-icon",
        html: `<div style="background-color: white; width: ${size}px; height: ${size}px; border: 2px solid ${color}; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 16px -4px rgb(0 0 0 / 0.1); color: ${color}; padding: 6px;">${icons[type] || ""}</div>`,
        iconSize: [size, size],
        iconAnchor: [size / 2, size / 2],
      });
    };

    const markers = {};
    L.marker(venue.coords, { icon: createCustomIcon("ring", true) })
      .addTo(map)
      .bindPopup("<b>Sokec</b>");

    transportOptions.forEach((opt) => {
      markers[opt.id] = L.marker(opt.marker.coords, {
        icon: createCustomIcon(opt.marker.icon),
      }).bindPopup(`<b>${opt.marker.title}</b>`);
    });

    markers["car"].addTo(map);

    const tabs = document.querySelectorAll(".transport-tab");
    const panels = document.querySelectorAll(".transport-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.getAttribute("data-tab");

        tabs.forEach((t) =>
          t.classList.remove("bg-wedding-dark", "text-wedding-light"),
        );
        tabs.forEach((t) => t.classList.add("text-wedding-dark/60"));
        tab.classList.add("bg-wedding-dark", "text-wedding-light");
        tab.classList.remove("text-wedding-dark/60");

        panels.forEach((p) => {
          p.classList.add("hidden", "opacity-0", "translate-y-4");
          p.classList.remove("opacity-100", "translate-y-0");
        });

        const activePanel = document.getElementById(`panel-${target}`);
        activePanel.classList.remove("hidden");
        // Trigger reflow for animation
        setTimeout(() => {
          activePanel.classList.add("opacity-100", "translate-y-0");
          activePanel.classList.remove("opacity-0", "translate-y-4");
        }, 10);

        Object.values(markers).forEach((m) => map.removeLayer(m));
        if (markers[target]) {
          markers[target].addTo(map);
          const group = L.featureGroup([
            L.marker(venue.coords),
            markers[target],
          ]);
          map.fitBounds(group.getBounds().pad(0.5));
        }
      });
    });

    setTimeout(() => map.invalidateSize(), 100);
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    border-radius: 0 !important;
    border: 1px solid #9a91a433;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1) !important;
  }
  .leaflet-popup-tip {
    display: none;
  }
  .custom-map-icon {
    background: none !important;
    border: none !important;
  }
</style>
