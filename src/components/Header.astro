---
import Navigation from "./Navigation.astro";
---

<header
  id="main-header"
  class="bg-wedding-light border-wedding-medium/20 sticky top-0 z-50 w-full border-b transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
    <div class="flex shrink-0 items-center">
      <a
        href="#top"
        id="logo-link"
        class="group flex items-center gap-4 text-xl font-bold whitespace-nowrap md:text-2xl"
      >
        <span>Hanka</span>
        <span class="flex items-center gap-1.5 md:gap-2">
          <span
            class="morse-decoder text-wedding-medium text-sm tracking-widest opacity-30 transition-all hover:opacity-100 md:text-base cursor-help"
            data-decoded="H"
            >····</span
          >
          <span
            class="morse-decoder text-wedding-medium text-sm tracking-widest opacity-30 transition-all hover:opacity-100 md:text-base cursor-help"
            data-decoded="F"
            >··−·</span
          >
        </span>
        <span>Filip</span>
      </a>
    </div>

    <div class="flex items-center gap-2">
      <!-- Sound Effect Toggle -->
      <button
        id="sound-toggle"
        class="border-wedding-medium/30 hover:border-wedding-dark text-wedding-medium hover:text-wedding-dark flex h-10 w-10 items-center justify-center border transition-all active:scale-95 cursor-pointer rounded-full shrink-0 select-none shadow-sm hover:bg-wedding-dark/5"
        aria-label="Toggle Morse Audio"
        title="Zapnout zvukovou telegrafii (Morseovy efekty)"
      >
        <svg id="sound-icon-muted" class="h-4 w-4 block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 5L6 9H2v6h4l5 4V5z"></path>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <svg id="sound-icon-unmuted" class="h-4 w-4 hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 5L6 9H2v6h4l5 4V5z"></path>
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
        </svg>
      </button>

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="z-50 flex flex-col gap-1.5 p-2 md:hidden cursor-pointer"
        aria-label="Toggle Menu"
      >
        <span
          class="bg-wedding-dark h-1 w-7 origin-center transition-all duration-300"
        ></span>
        <span class="bg-wedding-dark h-1 w-7 transition-all duration-300"></span>
        <span
          class="bg-wedding-dark h-1 w-7 origin-center transition-all duration-300"
        ></span>
      </button>
    </div>

    <Navigation />
  </div>
</header>

<script>
  // Handle Morse Sound Toggle
  const soundToggle = document.getElementById("sound-toggle");
  const iconMuted = document.getElementById("sound-icon-muted");
  const iconUnmuted = document.getElementById("sound-icon-unmuted");

  const updateSoundIcons = (enabled: boolean) => {
    if (enabled) {
      iconMuted?.classList.remove("block");
      iconMuted?.classList.add("hidden");
      iconUnmuted?.classList.remove("hidden");
      iconUnmuted?.classList.add("block");
      if (soundToggle) {
        soundToggle.title = "Vypnout zvukové telegrafní efekty";
      }
    } else {
      iconMuted?.classList.remove("hidden");
      iconMuted?.classList.add("block");
      iconUnmuted?.classList.remove("block");
      iconUnmuted?.classList.add("hidden");
      if (soundToggle) {
        soundToggle.title = "Zapnout zvukovou telegrafii (Morseovy efekty)";
      }
    }
  };

  // Read initial sound preference (default: false / muted)
  let soundEnabled = localStorage.getItem("morse-sound-enabled") === "true";
  updateSoundIcons(soundEnabled);

  soundToggle?.addEventListener("click", () => {
    soundEnabled = !soundEnabled;
    localStorage.setItem("morse-sound-enabled", String(soundEnabled));
    updateSoundIcons(soundEnabled);
    
    // Dispatch custom event to notify layout hover listeners
    window.dispatchEvent(new CustomEvent("morse-sound-toggled", { detail: { enabled: soundEnabled } }));
  });

  const menuToggle = document.getElementById("menu-toggle");
  const navMenu = document.getElementById("nav-menu");
  const menuSpans = menuToggle?.querySelectorAll("span");

  // Smooth scroll for logo
  const logoLink = document.getElementById("logo-link");
  logoLink?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
    // Update URL without reload
    history.pushState(null, "", import.meta.env.BASE_URL);
  });

  menuToggle?.addEventListener("click", () => {
    navMenu?.classList.toggle("hidden");
    navMenu?.classList.toggle("flex");

    // Animate hamburger to X
    if (menuSpans) {
      menuSpans[0].classList.toggle("rotate-45");
      menuSpans[0].classList.toggle("translate-y-2.5");
      menuSpans[1].classList.toggle("opacity-0");
      menuSpans[2].classList.toggle("-rotate-45");
      menuSpans[2].classList.toggle("-translate-y-2.5");
    }
  });

  // Close menu when clicking a link
  const navLinks = navMenu?.querySelectorAll("a");
  navLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      navMenu?.classList.add("hidden");
      navMenu?.classList.remove("flex");

      if (menuSpans) {
        menuSpans[0].classList.remove("rotate-45", "translate-y-2.5");
        menuSpans[1].classList.remove("opacity-0");
        menuSpans[2].classList.remove("-rotate-45", "-translate-y-2.5");
      }
    });
  });
</script>
