---
import Navigation from "./Navigation.astro";
---

<header
  id="main-header"
  class="bg-wedding-light border-wedding-medium/20 sticky top-0 z-50 w-full border-b transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
    <div class="flex shrink-0 items-center">
      <a
        href="#top"
        id="logo-link"
        class="group flex items-center gap-4 text-xl font-bold whitespace-nowrap md:text-2xl"
      >
        <span>Hanka</span>
        <span class="flex items-center gap-1.5 md:gap-2">
          <span
            class="morse-decoder text-wedding-medium text-sm tracking-widest opacity-30 transition-all hover:opacity-100 md:text-base cursor-help"
            data-decoded="H"
            >····</span
          >
          <span
            class="morse-decoder text-wedding-medium text-sm tracking-widest opacity-30 transition-all hover:opacity-100 md:text-base cursor-help"
            data-decoded="F"
            >··−·</span
          >
        </span>
        <span>Filip</span>
      </a>
    </div>

    <div class="flex items-center gap-2">

      <!-- Mobile Menu Button -->
      <button
        id="menu-toggle"
        class="z-50 flex flex-col gap-1.5 p-2 md:hidden cursor-pointer"
        aria-label="Toggle Menu"
      >
        <span
          class="bg-wedding-dark h-1 w-7 origin-center transition-all duration-300"
        ></span>
        <span class="bg-wedding-dark h-1 w-7 transition-all duration-300"></span>
        <span
          class="bg-wedding-dark h-1 w-7 origin-center transition-all duration-300"
        ></span>
      </button>
    </div>

    <Navigation />
  </div>
</header>

<script>

  const menuToggle = document.getElementById("menu-toggle");
  const navMenu = document.getElementById("nav-menu");
  const menuSpans = menuToggle?.querySelectorAll("span");

  // Smooth scroll for logo
  const logoLink = document.getElementById("logo-link");
  logoLink?.addEventListener("click", (e) => {
    e.preventDefault();
    window.scrollTo({
      top: 0,
      behavior: "smooth",
    });
    // Update URL without reload
    history.pushState(null, "", import.meta.env.BASE_URL);
  });

  menuToggle?.addEventListener("click", () => {
    navMenu?.classList.toggle("hidden");
    navMenu?.classList.toggle("flex");

    // Animate hamburger to X
    if (menuSpans) {
      menuSpans[0].classList.toggle("rotate-45");
      menuSpans[0].classList.toggle("translate-y-2.5");
      menuSpans[1].classList.toggle("opacity-0");
      menuSpans[2].classList.toggle("-rotate-45");
      menuSpans[2].classList.toggle("-translate-y-2.5");
    }
  });

  // Close menu when clicking a link
  const navLinks = navMenu?.querySelectorAll("a");
  navLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      navMenu?.classList.add("hidden");
      navMenu?.classList.remove("flex");

      if (menuSpans) {
        menuSpans[0].classList.remove("rotate-45", "translate-y-2.5");
        menuSpans[1].classList.remove("opacity-0");
        menuSpans[2].classList.remove("-rotate-45", "-translate-y-2.5");
      }
    });
  });
</script>
