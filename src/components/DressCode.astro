---
const dressCode = {
    title: "Dress Code",
    main: "Žádný.",
    detail: "Přijďte v tom, v čem se cítíte dobře.",
    subDetail: "Svatba se odehrává v interiéru i exteriéru, tak na to prosím myslete při výběru obuvi."
};
---

<section id="dress-code" class="py-24 max-w-4xl mx-auto px-6 scroll-mt-24">
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-20 flex items-center justify-center gap-4">
        <span class="text-wedding-gray opacity-20 text-2xl md:text-3xl tracking-tighter">−··</span>
        {dressCode.title}
        <span class="text-wedding-gray opacity-20 text-2xl md:text-3xl tracking-tighter">−·−·</span>
    </h2>
    <div class="border border-wedding-gray/20 bg-wedding-white p-16 md:p-24 text-center shadow-sm">
        <p class="text-4xl font-bold mb-4 tracking-tight">{dressCode.main}</p>
        <p class="text-wedding-gray text-xl italic font-medium opacity-90 mb-6">
            {dressCode.detail}
        </p>
        <div class="w-12 h-px bg-wedding-gray/20 mx-auto my-8"></div>
        <p class="text-xs text-wedding-gray uppercase tracking-[0.2em] font-bold opacity-80 max-w-sm mx-auto leading-relaxed">
            {dressCode.subDetail}
        </p>
    </div>
</section>
