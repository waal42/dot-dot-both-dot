---
// Fully schema-driven form configuration
const formSchema = [
  {
    section: "personal",
    grid: true,
    fields: [
      {
        id: "name",
        name: "name",
        label: "Jméno a příjmení",
        type: "text",
        required: true,
        placeholder: "Jan Novák",
        condition: null,
        options: [],
      },
      {
        id: "email",
        name: "email",
        label: "E-mail",
        type: "email",
        required: true,
        placeholder: "jan@seznam.cz",
        condition: null,
        options: [],
      },
    ],
  },
  {
    section: "attendance",
    fields: [
      {
        id: "attendance",
        name: "attendance",
        label: "Dorazíte?",
        type: "radio",
        condition: null,
        required: true,
        placeholder: null,
        options: [
          { value: "ano", label: "Ano, rád/a", checked: true },
          { value: "ne", label: "Bohužel ne", checked: false },
        ],
      },
    ],
  },
  {
    section: "children",
    divider: true,
    grid: true,
    fields: [
      {
        id: "coming-with-children",
        name: "coming_with_children",
        label: "Přijdete s dětmi?",
        type: "checkbox",
        text: "Ano",
        condition: null,
        required: false,
        placeholder: null,
        options: [],
      },
      {
        id: "how-many-children",
        name: "how_many_children",
        label: "Počet dětí",
        type: "text",
        condition: "coming-with-children",
        required: false,
        placeholder: "např. 2",
        options: [],
      },
    ],
  },
  {
    section: "lunch",
    divider: true,
    fields: [
      {
        id: "is-lunch-guest",
        name: "is_lunch_guest",
        label: "Jste pozváni na rodinný oběd?",
        type: "checkbox",
        text: "Ano",
        condition: null,
        required: false,
        placeholder: null,
        options: [],
      },
      {
        id: "coming-to-lunch",
        name: "coming_to_lunch",
        label: "Dorazíte na oběd?",
        type: "radio",
        condition: "is_lunch_guest",
        conditionValue: null,
        required: false,
        placeholder: null,
        options: [
          { value: "yes", label: "Ano", checked: false },
          { value: "no", label: "Ne", checked: false },
        ],
      },
    ],
  },
  {
    section: "additional",
    divider: true,
    fields: [
      {
        id: "diet",
        name: "diet",
        label: "Alergie / Dietní omezení",
        type: "text",
        placeholder: "např. bezlepková dieta, vegan...",
        condition: null,
        required: false,
        options: [],
      },
      {
        id: "song",
        name: "song",
        label: "Píseň, která mě zaručeně zvedne ze židle",
        type: "text",
        placeholder: "Název písně a interpret",
        condition: null,
        required: false,
        options: [],
      },
    ],
  },
];
---

<section id="rsvp" class="mx-auto max-w-3xl scroll-mt-24 px-6 py-24">
  <div class="mb-16 text-center">
    <h2
      class="text-wedding-dark mb-6 flex items-center justify-center gap-4 text-4xl font-bold md:text-5xl"
    >
      <span
        class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
        >··−</span
      >
      Účast
      <span
        class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
        >−·−·</span
      >
    </h2>
    <p
      class="text-wedding-dark text-base font-medium tracking-widest uppercase italic md:text-lg"
    >
      Prosíme o potvrzení účasti do 30. června 2026.
    </p>
  </div>

  <div
    class="morse-border text-wedding-medium/30 bg-wedding-light p-8 shadow-sm md:p-12"
  >
    <form id="rsvp-form" class="space-y-12">
      {
        formSchema.map((section) => (
          <div class={`space-y-6 ${section.divider ? "relative pt-12" : ""}`}>
            {section.divider && (
              <div class="morse-line text-wedding-medium/20 absolute top-0 left-0 h-[2px] w-full" />
            )}
            <div
              class={
                section.grid
                  ? "grid grid-cols-1 gap-6 md:grid-cols-2"
                  : "space-y-6"
              }
            >
              {section.fields.map((field) => (
                <div
                  id={`field-container-${field.id}`}
                  class={`space-y-2 ${field.condition ? "animate-in fade-in slide-in-from-top-2 hidden duration-500" : ""}`}
                  data-condition={field.condition}
                  data-condition-value={field.conditionValue}
                >
                  {/* Label for most types */}
                  {field.type !== "checkbox" && (
                    <label
                      for={field.id}
                      class="text-wedding-dark block text-sm font-bold tracking-widest uppercase"
                    >
                      {field.label}
                    </label>
                  )}

                  {/* Text & Email Inputs */}
                  {(field.type === "text" || field.type === "email") && (
                    <input
                      type={field.type}
                      id={field.id}
                      name={field.name}
                      required={field.required}
                      placeholder={field.placeholder}
                      class="border-wedding-medium/30 focus:border-wedding-dark placeholder:text-wedding-medium/60 w-full border-b bg-transparent py-4 text-lg transition-colors outline-none"
                    />
                  )}

                  {/* Radio Group */}
                  {field.type === "radio" && (
                    <div class="flex flex-wrap gap-x-12 gap-y-6 pt-3">
                      {field.options?.map((opt) => (
                        <label class="group flex cursor-pointer items-center gap-4">
                          <input
                            type="radio"
                            name={field.name}
                            value={opt.value}
                            checked={opt.checked}
                            class="peer hidden"
                          />
                          <div class="border-wedding-medium/60 peer-checked:border-wedding-dark flex h-7 w-7 items-center justify-center rounded-full border-2 transition-all peer-checked:[&>div]:scale-100">
                            <div class="bg-wedding-dark h-3.5 w-3.5 scale-0 rounded-full transition-transform" />
                          </div>
                          <span class="group-hover:text-wedding-medium text-wedding-dark text-lg font-semibold transition-colors">
                            {opt.label}
                          </span>
                        </label>
                      ))}
                    </div>
                  )}

                  {/* Select Input */}
                  {field.type === "select" && (
                    <select
                      id={field.id}
                      name={field.name}
                      class="border-wedding-medium/30 focus:border-wedding-dark text-wedding-dark w-full border bg-transparent p-4 text-lg font-semibold outline-none"
                    >
                      {field.options?.map((opt) => (
                        <option value={opt.value} class="text-wedding-dark">
                          {opt.label}
                        </option>
                      ))}
                    </select>
                  )}

                  {/* Checkbox Input */}
                  {field.type === "checkbox" && (
                    <div class="space-y-6">
                      <p class="text-wedding-dark text-sm font-bold tracking-widest uppercase">
                        {field.label}
                      </p>
                      <label class="group flex cursor-pointer items-center gap-4">
                        <input
                          type="checkbox"
                          id={field.id}
                          name={field.name}
                          class="peer hidden"
                        />
                        <div class="border-wedding-medium/60 peer-checked:border-wedding-dark flex h-7 w-7 items-center justify-center border-2 transition-all peer-checked:[&>svg]:scale-100">
                          <svg
                            class="text-wedding-dark h-5 w-5 scale-0 transition-transform"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="4"
                          >
                            <path d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="group-hover:text-wedding-medium text-wedding-dark text-lg font-semibold italic transition-colors">
                          {field.text}
                        </span>
                      </label>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }

      <button
        type="submit"
        id="submit-btn"
        class="bg-wedding-dark text-wedding-light hover:bg-wedding-medium group flex w-full items-center justify-center gap-6 px-8 py-5 font-bold tracking-[0.3em] uppercase transition-colors"
      >
        <span
          class="text-wedding-medium group-hover:text-wedding-light opacity-30 transition-all group-hover:opacity-60"
          >···</span
        >
        Odeslat potvrzení
        <span
          class="text-wedding-medium group-hover:text-wedding-light opacity-30 transition-all group-hover:opacity-60"
          >−−−</span
        >
      </button>

      <p
        id="form-status"
        class="hidden pt-4 text-center text-sm font-bold tracking-widest uppercase"
      >
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("rsvp-form") as HTMLFormElement;
  const statusMsg = document.getElementById("form-status");
  const submitBtn = document.getElementById("submit-btn");

  const updateVisibility = () => {
    if (!form) return;

    document.querySelectorAll("[data-condition]").forEach((container) => {
      const conditionKey = container.getAttribute("data-condition");
      const conditionValue = container.getAttribute("data-condition-value");
      if (!conditionKey) return;

      // Try finding by ID first
      let field = document.getElementById(
        conditionKey,
      ) as HTMLInputElement | null;

      // If not found or if it's not a checkbox/radio, try finding by Name (for radio groups)
      const inputsByName = form.querySelectorAll(
        `input[name="${conditionKey}"]`,
      ) as NodeListOf<HTMLInputElement>;

      let isVisible = false;

      if (inputsByName.length > 0) {
        // Handle Radio Groups or multiple inputs with same name
        const selectedInput = Array.from(inputsByName).find((i) => i.checked);
        if (conditionValue && conditionValue !== "null") {
          isVisible = selectedInput?.value === conditionValue;
        } else {
          isVisible =
            !!selectedInput &&
            (selectedInput.type !== "checkbox" || selectedInput.checked);
        }
      } else if (field) {
        // Handle single input by ID (like a checkbox)
        if (field.type === "checkbox") {
          isVisible = field.checked;
        } else {
          isVisible = !!field.value;
        }
      }

      if (isVisible) {
        container.classList.remove("hidden");
      } else {
        container.classList.add("hidden");
      }
    });
  };

  form?.addEventListener("change", updateVisibility);
  // Initial check
  updateVisibility();

  // Handle Form Submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!submitBtn || !statusMsg) return;

    submitBtn.setAttribute("disabled", "true");
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.innerHTML = "Odesílám...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.timestamp = new Date().toISOString();

    try {
      // URL is stored in private memory for later
      const GOOGLE_SCRIPT_URL = "YOUR_GOOGLE_SCRIPT_URL_HERE";
      console.log("RSVP Data:", data);

      // Success Simulation
      statusMsg.textContent = "Děkujeme! Vaše potvrzení bylo uloženo.";
      statusMsg.classList.remove("hidden", "text-red-500");
      statusMsg.classList.add("text-green-600");

      form.reset();
      updateVisibility();
    } catch (error) {
      statusMsg.textContent = "Chyba při odesílání. Zkuste to prosím znovu.";
      statusMsg.classList.remove("hidden", "text-green-600");
      statusMsg.classList.add("text-red-500");
    } finally {
      submitBtn.removeAttribute("disabled");
      submitBtn.innerHTML = originalBtnText;
    }
  });
</script>
