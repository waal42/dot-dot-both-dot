---
import { containsServerDirective } from "astro/runtime/server/render/server-islands.js";
import { redirectToDefaultLocale } from "astro:i18n";
import { navigate } from "astro:transitions/client";

// Fully schema-driven form configuration
const formSchema = [
  {
    section: "personal",
    grid: true,
    fields: [
      {
        id: "name",
        name: "name",
        label: "Jméno a příjmení",
        type: "text",
        required: true,
        placeholder: "Jan Novák",
        condition: null,
        options: [],
      },
      {
        id: "email",
        name: "email",
        label: "E-mail",
        type: "email",
        required: true,
        placeholder: "jan@seznam.cz",
        condition: null,
        options: [],
      },
    ],
  },
  {
    section: "attendance",
    fields: [
      {
        id: "attendance",
        name: "attendance",
        label: "Dorazíte?",
        type: "radio",
        condition: null,
        required: true,
        placeholder: null,
        options: [
          { value: "ano", label: "Ano, rád/a", checked: true },
          { value: "ne", label: "Bohužel ne" },
        ],
      },
    ],
  },
  {
    section: "lunch",
    divider: true,
    fields: [
      {
        id: "is-lunch-guest",
        name: "is_lunch_guest",
        label: "Jste pozváni na rodinný oběd?",
        type: "checkbox",
        text: "Ano, zúčastním se i oběda (13:00)",
        condition: null,
        required: false,
        placeholder: null,
        options: [],
      },
      {
        id: "meal",
        name: "meal",
        label: "Výběr hlavního chodu",
        type: "select",
        condition: "is-lunch-guest",
        required: true,
        placeholder: null,
        options: [
          { value: "svickova", label: "Tradiční svíčková na smetaně" },
          { value: "kure", label: "Pečené kuřecí prsíčko, bramborová kaše" },
          {
            value: "vegetarian",
            label: "Vegetariánské rizoto s lesními houbami",
          },
        ],
      },
    ],
  },
  {
    section: "additional",
    divider: true,
    fields: [
      {
        id: "diet",
        name: "diet",
        label: "Alergie / Dietní omezení",
        type: "text",
        placeholder: "např. bezlepková dieta, vegan...",
        condition: null,
        required: false,
        options: [],
      },
      {
        id: "song",
        name: "song",
        label: "Píseň, která mě zaručeně zvedne ze židle",
        type: "text",
        placeholder: "Název písně a interpret",
        condition: null,
        required: false,
        options: [],
      },
    ],
  },
];
---

<section id="rsvp" class="mx-auto max-w-3xl scroll-mt-24 px-6 py-24">
  <div class="mb-16 text-center">
    <h2
      class="mb-6 flex items-center justify-center gap-4 text-4xl font-bold md:text-5xl"
    >
      <span
        class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
        >··−</span
      >
      Účast
      <span
        class="text-wedding-gray text-2xl tracking-tighter opacity-20 md:text-3xl"
        >−·−·</span
      >
    </h2>
    <p
      class="text-wedding-gray text-sm font-medium tracking-widest uppercase italic opacity-90"
    >
      Prosíme o potvrzení účasti do 30. června 2026.
    </p>
  </div>

  <div
    class="bg-wedding-white border-wedding-gray/20 border p-8 shadow-sm md:p-12"
  >
    <form id="rsvp-form" class="space-y-8">
      {
        formSchema.map((section) => (
          <div
            class={`space-y-6 ${section.divider ? "border-wedding-gray/10 border-t pt-8" : ""}`}
          >
            <div
              class={
                section.grid
                  ? "grid grid-cols-1 gap-6 md:grid-cols-2"
                  : "space-y-6"
              }
            >
              {section.fields.map((field) => (
                <div
                  id={`field-container-${field.id}`}
                  class={`space-y-2 ${field.condition ? "animate-in fade-in slide-in-from-top-2 hidden duration-500" : ""}`}
                >
                  {/* Label for most types */}
                  {field.type !== "checkbox" && (
                    <label
                      for={field.id}
                      class="text-wedding-gray block text-xs font-bold tracking-widest uppercase"
                    >
                      {field.label}
                    </label>
                  )}

                  {/* Text & Email Inputs */}
                  {(field.type === "text" || field.type === "email") && (
                    <input
                      type={field.type}
                      id={field.id}
                      name={field.name}
                      required={field.required}
                      placeholder={field.placeholder}
                      class="border-wedding-gray/30 focus:border-wedding-black w-full border-b bg-transparent py-3 transition-colors outline-none"
                    />
                  )}

                  {/* Radio Group */}
                  {field.type === "radio" && (
                    <div class="flex gap-8 pt-2">
                      {field.options?.map((opt) => (
                        <label class="group flex cursor-pointer items-center gap-3">
                          <input
                            type="radio"
                            name={field.name}
                            value={opt.value}
                            checked={opt.checked}
                            class="peer hidden"
                          />
                          <div class="border-wedding-gray/40 peer-checked:border-wedding-black flex h-5 w-5 items-center justify-center rounded-full border transition-all">
                            <div class="bg-wedding-black h-2.5 w-2.5 scale-0 rounded-full transition-transform peer-checked:scale-100" />
                          </div>
                          <span class="group-hover:text-wedding-gray font-medium transition-colors">
                            {opt.label}
                          </span>
                        </label>
                      ))}
                    </div>
                  )}

                  {/* Select Input */}
                  {field.type === "select" && (
                    <select
                      id={field.id}
                      name={field.name}
                      class="border-wedding-gray/30 focus:border-wedding-black w-full border bg-transparent p-3 font-medium outline-none"
                    >
                      {field.options?.map((opt) => (
                        <option value={opt.value}>{opt.label}</option>
                      ))}
                    </select>
                  )}

                  {/* Checkbox Input */}
                  {field.type === "checkbox" && (
                    <div class="space-y-4">
                      <p class="text-wedding-gray text-xs font-bold tracking-widest uppercase">
                        {field.label}
                      </p>
                      <label class="group flex cursor-pointer items-center gap-3">
                        <input
                          type="checkbox"
                          id={field.id}
                          name={field.name}
                          class="peer hidden"
                        />
                        <div class="border-wedding-gray/40 peer-checked:border-wedding-black flex h-5 w-5 items-center justify-center border transition-all">
                          <svg
                            class="text-wedding-black h-3.5 w-3.5 scale-0 transition-transform peer-checked:scale-100"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="4"
                          >
                            <path d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="group-hover:text-wedding-gray text-sm font-medium italic transition-colors">
                          {field.text}
                        </span>
                      </label>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }

      <button
        type="submit"
        id="submit-btn"
        class="bg-wedding-black text-wedding-white hover:bg-wedding-gray group flex w-full items-center justify-center gap-6 px-8 py-5 font-bold tracking-[0.3em] uppercase transition-colors"
      >
        <span
          class="text-wedding-gray group-hover:text-wedding-white opacity-30 transition-all group-hover:opacity-60"
          >···</span
        >
        Odeslat potvrzení
        <span
          class="text-wedding-gray group-hover:text-wedding-white opacity-30 transition-all group-hover:opacity-60"
          >−−−</span
        >
      </button>

      <p
        id="form-status"
        class="hidden pt-4 text-center text-sm font-bold tracking-widest uppercase"
      >
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("rsvp-form") as HTMLFormElement;
  const statusMsg = document.getElementById("form-status");
  const submitBtn = document.getElementById("submit-btn");

  // Conditional logic based on schema
  const lunchCheckbox = document.getElementById(
    "is-lunch-guest",
  ) as HTMLInputElement;
  const mealField = document.getElementById("field-container-meal");

  lunchCheckbox?.addEventListener("change", () => {
    if (lunchCheckbox.checked) {
      mealField?.classList.remove("hidden");
    } else {
      mealField?.classList.add("hidden");
    }
  });

  // Handle Form Submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!submitBtn || !statusMsg) return;

    submitBtn.setAttribute("disabled", "true");
    submitBtn.innerHTML = "Odesílám...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.timestamp = new Date().toISOString();

    try {
      // URL is stored in private memory for later
      const GOOGLE_SCRIPT_URL = "YOUR_GOOGLE_SCRIPT_URL_HERE";
      console.log("RSVP Data:", data);

      // Success Simulation
      statusMsg.textContent = "Děkujeme! Vaše potvrzení bylo uloženo.";
      statusMsg.classList.remove("hidden", "text-red-500");
      statusMsg.classList.add("text-green-600");

      form.reset();
      mealField?.classList.add("hidden");
    } catch (error) {
      statusMsg.textContent = "Chyba při odesílání. Zkuste to prosím znovu.";
      statusMsg.classList.remove("hidden", "text-green-600");
      statusMsg.classList.add("text-red-500");
    } finally {
      submitBtn.removeAttribute("disabled");
      submitBtn.innerHTML = "Odeslat potvrzení";
    }
  });
</script>
