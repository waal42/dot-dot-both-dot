---
import { containsServerDirective } from "astro/runtime/server/render/server-islands.js";
import { redirectToDefaultLocale } from "astro:i18n";
import { navigate } from "astro:transitions/client";

// Fully schema-driven form configuration
const formSchema = [
  {
    section: "personal",
    grid: true,
    fields: [
      { id: "name", name: "name", label: "Jméno a příjmení", type: "text", required: true, placeholder: "Jan Novák", condition: null, options: [] },
      { id: "email", name: "email", label: "E-mail", type: "email", required: true, placeholder: "jan@seznam.cz", condition: null, options: [] }
    ]
  },
  {
    section: "attendance",
    fields: [
      {
        id: "attendance",
        name: "attendance",
        label: "Dorazíte?",
        type: "radio",
        condition: null,
        required: true,
        placeholder: null,
        options: [
          { value: "ano", label: "Ano, rád/a", checked: true },
          { value: "ne", label: "Bohužel ne" }
        ]
      }
    ]
  },
  {
    section: "lunch",
    divider: true,
    fields: [
      {
        id: "is-lunch-guest",
        name: "is_lunch_guest",
        label: "Jste pozváni na rodinný oběd?",
        type: "checkbox",
        text: "Ano, zúčastním se i oběda (13:00)",
        condition: null,
        required: false,
        placeholder: null,
        options: []
      },
      {
        id: "meal",
        name: "meal",
        label: "Výběr hlavního chodu",
        type: "select",
        condition: "is-lunch-guest",
        required: true,
        placeholder: null,
        options: [
          { value: "svickova", label: "Tradiční svíčková na smetaně" },
          { value: "kure", label: "Pečené kuřecí prsíčko, bramborová kaše" },
          { value: "vegetarian", label: "Vegetariánské rizoto s lesními houbami" }
        ]
      }
    ]
  },
  {
    section: "additional",
    divider: true,
    fields: [
      { id: "diet", name: "diet", label: "Alergie / Dietní omezení", type: "text", placeholder: "např. bezlepková dieta, vegan...", condition: null, required: false, options: [] },
      { id: "song", name: "song", label: "Píseň, která mě zaručeně zvedne ze židle", type: "text", placeholder: "Název písně a interpret", condition: null, required: false, options: [] }
    ]
  }
];
---

<section id="rsvp" class="py-24 max-w-3xl mx-auto px-6 scroll-mt-24">
  <div class="text-center mb-16">
    <h2 class="text-4xl md:text-5xl font-bold mb-6 flex items-center justify-center gap-4">
        <span class="text-wedding-gray opacity-20 text-2xl md:text-3xl tracking-tighter">··−</span>
        Účast
        <span class="text-wedding-gray opacity-20 text-2xl md:text-3xl tracking-tighter">−·−·</span>
    </h2>
    <p class="text-wedding-gray font-medium uppercase tracking-widest text-sm italic opacity-90">Prosíme o potvrzení účasti do 30. června 2026.</p>
  </div>

  <div class="bg-wedding-white border border-wedding-gray/20 p-8 md:p-12 shadow-sm">
    <form id="rsvp-form" class="space-y-8">

      {formSchema.map((section) => (
        <div class={`space-y-6 ${section.divider ? 'pt-8 border-t border-wedding-gray/10' : ''}`}>
          <div class={section.grid ? 'grid grid-cols-1 md:grid-cols-2 gap-6' : 'space-y-6'}>

            {section.fields.map((field) => (
              <div id={`field-container-${field.id}`} class={`space-y-2 ${field.condition ? 'hidden animate-in fade-in slide-in-from-top-2 duration-500' : ''}`}>

                {/* Label for most types */}
                {field.type !== 'checkbox' && (
                  <label for={field.id} class="block text-xs font-bold uppercase tracking-widest text-wedding-gray">{field.label}</label>
                )}

                {/* Text & Email Inputs */}
                {(field.type === 'text' || field.type === 'email') && (
                  <input
                    type={field.type}
                    id={field.id}
                    name={field.name}
                    required={field.required}
                    placeholder={field.placeholder}
                    class="w-full border-b border-wedding-gray/30 py-3 focus:border-wedding-black outline-none transition-colors bg-transparent"
                  />
                )}

                {/* Radio Group */}
                {field.type === 'radio' && (
                  <div class="flex gap-8 pt-2">
                    {field.options?.map((opt) => (
                      <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="radio" name={field.name} value={opt.value} checked={opt.checked} class="hidden peer" />
                        <div class="w-5 h-5 border border-wedding-gray/40 rounded-full flex items-center justify-center peer-checked:border-wedding-black transition-all">
                            <div class="w-2.5 h-2.5 bg-wedding-black rounded-full scale-0 peer-checked:scale-100 transition-transform"></div>
                        </div>
                        <span class="font-medium group-hover:text-wedding-gray transition-colors">{opt.label}</span>
                      </label>
                    ))}
                  </div>
                )}

                {/* Select Input */}
                {field.type === 'select' && (
                  <select
                      id={field.id}
                      name={field.name}
                      class="w-full border border-wedding-gray/30 p-3 focus:border-wedding-black outline-none bg-transparent font-medium"
                  >
                      {field.options?.map((opt) => (
                        <option value={opt.value}>{opt.label}</option>
                      ))}
                  </select>
                )}

                {/* Checkbox Input */}
                {field.type === 'checkbox' && (
                  <div class="space-y-4">
                    <p class="text-xs font-bold uppercase tracking-widest text-wedding-gray">{field.label}</p>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" id={field.id} name={field.name} class="hidden peer" />
                        <div class="w-5 h-5 border border-wedding-gray/40 flex items-center justify-center peer-checked:border-wedding-black transition-all">
                            <svg class="w-3.5 h-3.5 text-wedding-black scale-0 peer-checked:scale-100 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="4">
                                <path d="M5 13l4 4L19 7"></path>
                            </svg>
                        </div>
                        <span class="font-medium group-hover:text-wedding-gray transition-colors italic text-sm">{field.text}</span>
                    </label>
                  </div>
                )}

              </div>
            ))}
          </div>
        </div>
      ))}

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-wedding-black text-wedding-white font-bold py-5 px-8 hover:bg-wedding-gray transition-colors uppercase tracking-[0.3em] flex items-center justify-center gap-6 group"
      >
        <span class="text-wedding-gray opacity-30 group-hover:text-wedding-white group-hover:opacity-60 transition-all">···</span>
        Odeslat potvrzení
        <span class="text-wedding-gray opacity-30 group-hover:text-wedding-white group-hover:opacity-60 transition-all">−−−</span>
      </button>

      <p id="form-status" class="hidden text-center font-bold uppercase tracking-widest text-sm pt-4"></p>
    </form>
  </div>
</section>

<script>
    const form = document.getElementById('rsvp-form') as HTMLFormElement;
    const statusMsg = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn');

    // Conditional logic based on schema
    const lunchCheckbox = document.getElementById('is-lunch-guest') as HTMLInputElement;
    const mealField = document.getElementById('field-container-meal');

    lunchCheckbox?.addEventListener('change', () => {
        if (lunchCheckbox.checked) {
            mealField?.classList.remove('hidden');
        } else {
            mealField?.classList.add('hidden');
        }
    });

    // Handle Form Submission
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitBtn || !statusMsg) return;

        submitBtn.setAttribute('disabled', 'true');
        submitBtn.innerHTML = 'Odesílám...';

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.timestamp = new Date().toISOString();

        try {
            // URL is stored in private memory for later
            const GOOGLE_SCRIPT_URL = 'YOUR_GOOGLE_SCRIPT_URL_HERE';
            console.log('RSVP Data:', data);

            // Success Simulation
            statusMsg.textContent = 'Děkujeme! Vaše potvrzení bylo uloženo.';
            statusMsg.classList.remove('hidden', 'text-red-500');
            statusMsg.classList.add('text-green-600');

            form.reset();
            mealField?.classList.add('hidden');

        } catch (error) {
            statusMsg.textContent = 'Chyba při odesílání. Zkuste to prosím znovu.';
            statusMsg.classList.remove('hidden', 'text-green-600');
            statusMsg.classList.add('text-red-500');
        } finally {
            submitBtn.removeAttribute('disabled');
            submitBtn.innerHTML = 'Odeslat potvrzení';
        }
    });
</script>
