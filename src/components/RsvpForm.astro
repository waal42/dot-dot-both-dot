---
// src/components/RsvpForm.astro
import { getEntry } from "astro:content";

const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { rsvpForm } = wedding.data;
---

<section id="rsvp" class="mx-auto max-w-3xl scroll-mt-24 px-6 py-24">
  <div class="mb-16 text-center">
    <h2
      class="text-wedding-dark mb-6 flex items-center justify-center gap-4 text-4xl font-bold md:text-5xl animate-fade-in-up"
    >
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
        data-decoded="U"
        >··−</span
      >
      {rsvpForm.title}
      <span
        class="morse-decoder text-wedding-medium text-2xl tracking-tighter opacity-30 md:text-3xl hover:opacity-100"
        data-decoded="T"
        >−</span
      >
    </h2>
    <p
      class="text-wedding-dark text-base font-medium tracking-widest uppercase italic md:text-lg opacity-80 animate-fade-in-up delay-100"
    >
      {rsvpForm.description}
    </p>
  </div>

  <div
    class="morse-border text-wedding-medium/30 bg-wedding-light p-8 shadow-sm md:p-12 animate-fade-in-up delay-200"
  >
    <form id="rsvp-form" class="space-y-12">
      {
        rsvpForm.schema.map((section) => (
          <div class={`space-y-6 ${section.divider ? "relative pt-12" : ""}`}>
            {section.divider && (
              <div class="morse-line text-wedding-medium/20 absolute top-0 left-0 h-[2px] w-full" />
            )}
            <div
              class={
                section.grid
                  ? "grid grid-cols-1 gap-6 md:grid-cols-2"
                  : "space-y-6"
              }
            >
              {section.fields.map((field) => (
                <div
                  id={`field-container-${field.id}`}
                  class={`space-y-2 ${field.condition ? "animate-in fade-in slide-in-from-top-2 hidden duration-500" : ""}`}
                  data-condition={field.condition}
                  data-condition-value={field.conditionValue}
                >
                  {/* Label for most types */}
                  {field.type !== "checkbox" && (
                    <label
                      for={field.id}
                      class="text-wedding-dark block text-xs font-bold tracking-widest uppercase opacity-80"
                    >
                      {field.label}
                    </label>
                  )}

                  {/* Text & Email Inputs */}
                  {(field.type === "text" || field.type === "email") && (
                    <input
                      type={field.type}
                      id={field.id}
                      name={field.name}
                      required={field.required}
                      placeholder={field.placeholder}
                      class="border-wedding-medium/30 focus:border-wedding-dark placeholder:text-wedding-medium/40 w-full border-b bg-transparent py-4 text-lg font-medium text-wedding-dark transition-colors outline-none focus:ring-0"
                    />
                  )}

                  {/* Radio Group */}
                  {field.type === "radio" && (
                    <div class="flex flex-wrap gap-x-12 gap-y-6 pt-3">
                      {field.options?.map((opt) => (
                        <label class="group flex cursor-pointer items-center gap-4">
                          <input
                            type="radio"
                            name={field.name}
                            value={opt.value}
                            checked={opt.checked}
                            class="peer hidden"
                          />
                          <div class="border-wedding-medium/60 peer-checked:border-wedding-dark flex h-7 w-7 items-center justify-center rounded-full border-2 transition-all peer-checked:[&>div]:scale-100">
                            <div class="bg-wedding-dark h-3.5 w-3.5 scale-0 rounded-full transition-transform" />
                          </div>
                          <span class="group-hover:text-wedding-medium text-wedding-dark text-lg font-semibold transition-colors">
                            {opt.label}
                          </span>
                        </label>
                      ))}
                    </div>
                  )}

                  {/* Select Input */}
                  {field.type === "select" && (
                    <select
                      id={field.id}
                      name={field.name}
                      class="border-wedding-medium/30 focus:border-wedding-dark text-wedding-dark w-full border bg-transparent p-4 text-lg font-semibold outline-none"
                    >
                      {field.options?.map((opt) => (
                        <option value={opt.value} class="text-wedding-dark">
                          {opt.label}
                        </option>
                      ))}
                    </select>
                  )}

                  {/* Checkbox Input */}
                  {field.type === "checkbox" && (
                    <div class="space-y-4">
                      <p class="text-wedding-dark text-xs font-bold tracking-widest uppercase opacity-85">
                        {field.label}
                      </p>
                      <label class="group flex cursor-pointer items-center gap-4">
                        <input
                          type="checkbox"
                          id={field.id}
                          name={field.name}
                          class="peer hidden"
                        />
                        <div class="border-wedding-medium/60 peer-checked:border-wedding-dark flex h-7 w-7 items-center justify-center border-2 transition-all peer-checked:[&>svg]:scale-100">
                          <svg
                            class="text-wedding-dark h-5 w-5 scale-0 transition-transform"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="4"
                          >
                            <path d="M5 13l4 4L19 7" />
                          </svg>
                        </div>
                        <span class="group-hover:text-wedding-medium text-wedding-dark text-lg font-semibold italic transition-colors">
                          {field.text}
                        </span>
                      </label>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))
      }

      <button
        type="submit"
        id="submit-btn"
        class="bg-wedding-dark text-wedding-light hover:bg-wedding-medium group flex w-full items-center justify-center gap-6 px-8 py-5 font-bold tracking-[0.3em] uppercase transition-colors cursor-pointer rounded-sm"
      >
        <span
          class="morse-decoder text-wedding-medium group-hover:text-wedding-light opacity-30 transition-all group-hover:opacity-60"
          data-decoded="S"
          >···</span
        >
        {rsvpForm.submitButtonText}
        <span
          class="morse-decoder text-wedding-medium group-hover:text-wedding-light opacity-30 transition-all group-hover:opacity-60"
          data-decoded="O"
          >−−−</span
        >
      </button>

      <p
        id="form-status"
        class="hidden pt-4 text-center text-sm font-bold tracking-widest uppercase"
      >
      </p>
    </form>
  </div>
</section>

<script define:vars={{ rsvpForm }}>
  const form = document.getElementById("rsvp-form");
  const statusMsg = document.getElementById("form-status");
  const submitBtn = document.getElementById("submit-btn");

  const updateVisibility = () => {
    if (!form) return;

    document.querySelectorAll("[data-condition]").forEach((container) => {
      const conditionKey = container.getAttribute("data-condition");
      const conditionValue = container.getAttribute("data-condition-value");
      if (!conditionKey) return;

      // Try finding by ID first
      let field = document.getElementById(conditionKey);

      // If not found or if it's not a checkbox/radio, try finding by Name (for radio groups)
      const inputsByName = form.querySelectorAll(`input[name="${conditionKey}"]`);

      let isVisible = false;

      if (inputsByName.length > 0) {
        // Handle Radio Groups or multiple inputs with same name
        const selectedInput = Array.from(inputsByName).find((i) => i.checked);
        if (conditionValue && conditionValue !== "null") {
          isVisible = selectedInput?.value === conditionValue;
        } else {
          isVisible =
            !!selectedInput &&
            (selectedInput.type !== "checkbox" || selectedInput.checked);
        }
      } else if (field) {
        // Handle single input by ID (like a checkbox)
        if (field.type === "checkbox") {
          isVisible = field.checked;
        } else {
          isVisible = !!field.value;
        }
      }

      if (isVisible) {
        container.classList.remove("hidden");
      } else {
        container.classList.add("hidden");
      }
    });
  };

  form?.addEventListener("change", updateVisibility);
  // Initial check
  updateVisibility();

  // Handle Form Submission
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!submitBtn || !statusMsg) return;

    submitBtn.setAttribute("disabled", "true");
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.innerHTML = rsvpForm.sendingText;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    data.timestamp = new Date().toISOString();

    try {
      console.log("RSVP Data Submitted:", data);

      // Elegant Success Card State loaded from Config
      const formCard = form.parentElement;
      if (formCard) {
        formCard.innerHTML = `
          <div class="text-center py-16 px-6 animate-fade-in-up">
            <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-wedding-dark text-wedding-light shadow-md animate-bounce">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <h3 class="text-wedding-dark text-3xl font-bold mb-4">${rsvpForm.successMessage.title}</h3>
            <p class="text-wedding-medium text-lg font-medium italic mb-8 max-w-md mx-auto leading-relaxed">
              ${rsvpForm.successMessage.subtitle}
            </p>
            <div class="morse-line text-wedding-medium/30 mx-auto h-[2px] w-32 mb-8"></div>
            <p class="text-wedding-dark text-xs font-bold tracking-[0.4em] uppercase opacity-60">
              ${rsvpForm.successMessage.morseCode}
            </p>
          </div>
        `;
      }
    } catch (error) {
      statusMsg.textContent = rsvpForm.errorMessage;
      statusMsg.classList.remove("hidden", "text-green-600");
      statusMsg.classList.add("text-red-500");
      submitBtn.removeAttribute("disabled");
      submitBtn.innerHTML = originalBtnText;
    }
  });
</script>
