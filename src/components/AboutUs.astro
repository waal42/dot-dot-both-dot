---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import imgLublan from "../assets/lublan.jpg";
import imgSifrovacka from "../assets/sifrovacka.jpg";
import imgMyvali from "../assets/myvali.jpg";
import imgSaline from "../assets/salina.jpg";
import imgFabar from "../assets/fabar.jpg";
import imgVytah from "../assets/vytah.jpg";
import imgVytah2 from "../assets/vytah2.jpg";
import imgPlac from "../assets/plac.jpg";
import imgCap from "../assets/cap.jpg";
import imgKokorinsko from "../assets/kokorinsko.jpg";
import imgKokorinsko2 from "../assets/kokorinsko2.jpg";
import imgMore from "../assets/more.jpg";
import imgParek from "../assets/parek.jpg";
import imgSbeerka from "../assets/sbeerka.jpg";
import imgStehovani from "../assets/stehovani.jpg";
import imgSvetry from "../assets/svetry.jpg";
import imgTmou from "../assets/tmou.jpg";
import imgViden from "../assets/viden.jpg";
import imgWuppertal from "../assets/wuppertal.jpg";

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
  size: "small" | "large" | "vertical" | "horizontal";
  type?: "image";
}

interface GalleryText {
  src: null;
  alt: string;
  type: "text";
  title: string;
  detail: string;
  size: "small" | "large" | "vertical" | "horizontal";
}

type GalleryItem = GalleryImage | GalleryText;

// Gallery configuration for easy management
const galleryItems: GalleryItem[] = [
  { src: imgLublan, alt: "V Lublani", size: "large" },
  { src: imgSifrovacka, alt: "Na šifrovačce", size: "small" },
  { src: imgVytah2, alt: "Ve výtahu", size: "vertical" },
  {
    src: null,
    alt: "",
    type: "text",
    title: "Hanka & Filip",
    detail: "nějakej totálně cringe text",
    size: "small",
  },
  { src: imgSaline, alt: "V šalině", size: "horizontal" },
  { src: imgPlac, alt: "Společný pláč", size: "horizontal" },
  { src: imgMyvali, alt: "My jsme mývalové", size: "vertical" },
  { src: imgFabar, alt: "V F.A. baru", size: "horizontal" },
  { src: imgVytah, alt: "Ve výtahu", size: "small" },
  { src: imgStehovani, alt: "Malování po stěhování", size: "large" },
  { src: imgSvetry, alt: "Ve vánočních svetrch", size: "vertical" },
  { src: imgTmou, alt: "Na Tmou", size: "vertical" },
  { src: imgViden, alt: "Ve Vídni", size: "horizontal" },
  { src: imgParek, alt: "Na Párku", size: "vertical" },
  { src: imgWuppertal, alt: "Ve Wuppertalu", size: "horizontal" },
  { src: imgMore, alt: "U moře", size: "small" },
  { src: imgCap, alt: "U Čápa", size: "horizontal" },
  { src: imgSbeerka, alt: "Ve Sbeerce", size: "horizontal" },
  { src: imgKokorinsko, alt: "Pod Kokořínem", size: "horizontal" },
  { src: imgKokorinsko2, alt: "Pořád pod Kokořínem", size: "horizontal" },
];

const getSizeClasses = (size: string) => {
  switch (size) {
    case "large":
      return "col-span-2 row-span-2";
    case "vertical":
      return "col-span-1 row-span-2";
    case "horizontal":
      return "col-span-2 row-span-1";
    default:
      return "col-span-1 row-span-1";
  }
};
---

<section id="o-nas" class="mx-auto max-w-6xl scroll-mt-24 px-6 py-24">
  <h2
    class="text-wedding-dark mb-20 flex items-center justify-center gap-4 text-center text-4xl font-bold md:text-5xl"
  >
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >−−·</span
    >
    O nás
    <span
      class="text-wedding-medium text-2xl tracking-tighter opacity-20 md:text-3xl"
      >·−·−</span
    >
  </h2>

  <div
    id="gallery"
    class="grid auto-rows-[150px] grid-cols-2 gap-3 md:auto-rows-[300px] md:grid-cols-4 md:gap-4"
  >
    {
      galleryItems.map((item) => (
        <div
          class={`${getSizeClasses(item.size)} group bg-wedding-dark/5 overflow-hidden`}
        >
          {item.type === "text" ? (
            <div class="border-wedding-medium/20 bg-wedding-light flex h-full flex-col items-center justify-center border p-4 text-center md:p-8">
              <p class="text-wedding-dark mb-2 text-xl font-bold md:text-2xl">
                {item.title}
              </p>
              <div class="morse-line text-wedding-medium/40 my-4 h-[2px] w-24 md:my-6 md:w-40" />
              <p class="text-wedding-medium text-[10px] font-bold tracking-[0.3em] uppercase md:text-xs">
                {item.detail}
              </p>
            </div>
          ) : (
            <a
              href={item.src.src}
              data-pswp-width={item.src.width}
              data-pswp-height={item.src.height}
              target="_blank"
              class="block h-full w-full cursor-zoom-in"
            >
              <Image
                src={item.src}
                alt={item.alt}
                class="h-full w-full scale-105 object-cover grayscale transition-all duration-700 group-hover:scale-100 group-hover:grayscale-0 md:grayscale"
              />
            </a>
          )}
        </div>
      ))
    }
  </div>

  <div class="mx-auto mt-20 max-w-2xl text-center">
    <p
      class="text-wedding-dark text-xl leading-relaxed font-medium italic md:text-2xl"
    >
      "Jsme dva, co se našli u kódu, šifer a dobrého kafe. Naše cesta nás
      zavedla z brněnských uliček až k tomuto dni, o který se s vámi chceme
      podělit." -Gemini
    </p>
  </div>
</section>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";

  const lightbox = new PhotoSwipeLightbox({
    gallery: "#gallery",
    children: "a",
    pswpModule: () => import("photoswipe"),
    // Add some padding for mobile
    padding: { top: 20, bottom: 20, left: 10, right: 10 },
  });
  lightbox.init();
</script>
