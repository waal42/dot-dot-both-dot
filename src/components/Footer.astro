---
import { getEntry } from "astro:content";


const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { morseMessage } = wedding.data;
---

<footer
  class="bg-wedding-light text-wedding-dark border-wedding-medium/20 mt-16 border-t py-24 text-center"
>
  <div class="mx-auto max-w-6xl px-6">
    <div
      class="mb-12 flex flex-col items-center justify-center gap-8 text-4xl font-bold tracking-tight md:flex-row md:text-6xl"
    >
      <div class="flex items-center gap-4">
        <span class="opacity-60">H</span>
        <span 
          class="morse-decoder text-3xl opacity-30 hover:opacity-100 transition-all cursor-help md:text-4xl" 
          data-decoded="H"
          >····</span
        >
      </div>
      <span class="mx-4 hidden text-4xl font-light opacity-20 md:block">/</span>
      <div class="flex items-center gap-4">
        <span class="opacity-60">F</span>
        <span 
          class="morse-decoder text-3xl opacity-30 hover:opacity-100 transition-all cursor-help md:text-4xl" 
          data-decoded="F"
          >··−·</span
        >
      </div>
    </div>
    
    <p class="mb-2 text-3xl font-bold text-wedding-dark">Těšíme se na vás!</p>
    <p class="text-wedding-dark text-lg font-bold tracking-[0.2em] uppercase">
      Hanka & Filip
    </p>
    <p
      class="text-wedding-medium mt-3 text-sm font-bold tracking-widest uppercase"
    >
      Šlapanice, 15. srpna 2026
    </p>

    <div class="mt-10">
      <button
        id="open-morse-modal"
        class="morse-border text-wedding-dark border-wedding-dark hover:bg-wedding-dark hover:text-wedding-light mt-8 inline-flex items-center gap-3 bg-transparent px-12 py-5 text-lg font-bold tracking-widest uppercase transition-all duration-300 animate-fade-in-up delay-200 hover:scale-105 active:scale-95 shadow-sm"
      >
        {morseMessage.buttonText}
      </button>
    </div>
    
    <!-- 🦝 MÝVALÍ MINI-ŠIFRA GAME -->
    <div class="mt-16 max-w-md mx-auto p-6 bg-wedding-light/50 border border-wedding-medium/20 shadow-sm rounded-sm hover-card-premium">
      <h4 class="text-wedding-dark font-bold text-sm tracking-widest uppercase mb-3 flex items-center justify-center gap-2">
        🦝 Mývalí mini-šifra
      </h4>
      <p class="text-wedding-dark text-xs italic font-medium opacity-80 mb-5 leading-relaxed">
        Dokážeš rozluštit tajný kód pro vstup k mývalům?
      </p>
      
      <!-- Morse Code to decode -->
      <div class="mb-5 py-3.5 bg-wedding-dark/5 border border-wedding-medium/10 rounded-sm">
        <p class="text-wedding-dark text-lg font-bold tracking-[0.25em] select-all">
          −− &nbsp; −·−− &nbsp; ···− &nbsp; ·− &nbsp; ·−·· &nbsp; −−− &nbsp; ···− &nbsp; ·
        </p>
      </div>

      <!-- Interactive Inputs -->
      <div id="game-controls" class="flex gap-2">
        <input 
          type="text" 
          id="game-input" 
          placeholder="Tvoje odpověď..." 
          class="border-wedding-medium/30 focus:border-wedding-dark text-wedding-dark px-3 py-2 text-sm bg-transparent border rounded-sm outline-none flex-1 font-bold tracking-widest uppercase placeholder:text-wedding-medium/40"
        />
        <button 
          id="game-btn" 
          class="border border-wedding-dark text-wedding-dark hover:bg-wedding-dark hover:text-wedding-light px-5 py-2 text-xs font-bold tracking-widest uppercase rounded-sm cursor-pointer transition-all duration-300 hover:scale-105 active:scale-95 shadow-sm"
        >
          Ověřit
        </button>
      </div>
      
      <!-- Output Message (Initially Hidden) -->
      <div id="game-success" class="hidden mt-6 text-center animate-fade-in-up">
        <div class="morse-line text-wedding-medium/20 mx-auto h-[2px] w-24 mb-4"></div>
        <p class="text-wedding-dark text-sm font-bold mb-1">🎉 Kód je správný! Vítej v mývalím doupěti.</p>
        <p class="text-wedding-medium text-[10px] font-medium italic mb-4">
          Tady je tvůj tajný mývalí maskot:
        </p>
        <!-- Cute Text Art Raccoons -->
        <pre class="text-wedding-dark text-[10px] leading-tight font-mono inline-block text-left p-3.5 bg-wedding-dark/5 border border-wedding-medium/15 rounded-sm select-all">
       ( -\_- )     ( -\_- )
       /     \\=====/     \\
      |  (o)  | ❤  |  (o)  |
       \\     /=====\\     /
        `---'         `---'
        </pre>
      </div>
      
      <p id="game-error" class="hidden mt-3 text-xs text-red-600 font-bold tracking-widest uppercase animate-pulse">
        Kód nesouhlasí, zkus to znovu!
      </p>
    </div>
  </div>
</footer>

<script>
  const gameInput = document.getElementById("game-input") as HTMLInputElement;
  const gameBtn = document.getElementById("game-btn");
  const gameSuccess = document.getElementById("game-success");
  const gameError = document.getElementById("game-error");
  const gameControls = document.getElementById("game-controls");

  gameBtn?.addEventListener("click", () => {
    if (!gameInput || !gameSuccess || !gameError || !gameControls) return;
    
    // Normalize input (ignore case, spaces, diacritics)
    const answer = gameInput.value
      .trim()
      .toUpperCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "") // remove diacritics
      .replace(/\s+/g, ""); // remove spaces

    if (answer === "MYVALOVE") {
      gameError.classList.add("hidden");
      gameControls.classList.add("hidden");
      gameSuccess.classList.remove("hidden");
      
      // Save puzzle state in localStorage so it stays solved on reload!
      localStorage.setItem("myvalove_puzzle_solved", "true");
    } else {
      gameError.classList.remove("hidden");
      // Hide error after 3 seconds
      setTimeout(() => {
        gameError.classList.add("hidden");
      }, 3000);
    }
  });

  // Listen for Enter key
  gameInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      gameBtn?.click();
    }
  });

  // Check if solved on mount
  if (localStorage.getItem("myvalove_puzzle_solved") === "true") {
    if (gameControls && gameSuccess) {
      gameControls.classList.add("hidden");
      gameSuccess.classList.remove("hidden");
    }
  }
</script>
