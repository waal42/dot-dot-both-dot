---
import { getEntry } from "astro:content";

const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { morseMessage } = wedding.data;
---

<footer
  class="bg-wedding-light text-wedding-dark border-wedding-medium/20 mt-16 border-t py-24 text-center"
>
  <div class="mx-auto max-w-6xl px-6">
    <div
      class="mb-12 flex flex-col items-center justify-center gap-8 text-4xl font-bold tracking-tight md:flex-row md:text-6xl"
    >
      <div class="flex items-center gap-4">
        <span class="opacity-60">H</span>
        <span
          class="morse-decoder cursor-help text-3xl opacity-30 transition-all hover:opacity-100 md:text-4xl"
          data-decoded="H">····</span
        >
      </div>
      <span class="mx-4 hidden text-4xl font-light opacity-20 md:block">/</span>
      <div class="flex items-center gap-4">
        <span class="opacity-60">F</span>
        <span
          class="morse-decoder cursor-help text-3xl opacity-30 transition-all hover:opacity-100 md:text-4xl"
          data-decoded="F">··−·</span
        >
      </div>
    </div>

    <p class="text-wedding-dark mb-2 text-3xl font-bold">Těšíme se na vás!</p>
    <p class="text-wedding-dark text-lg font-bold tracking-[0.2em] uppercase">
      Hanka & Filip
    </p>
    <p
      class="text-wedding-medium mt-3 text-sm font-bold tracking-widest uppercase"
    >
      Šlapanice, 15. srpna 2026
    </p>

    <div class="mt-10">
      <button
        id="open-morse-modal"
        aria-haspopup="dialog"
        aria-controls="morse-modal"
        aria-expanded="false"
        class="morse-border text-wedding-dark border-wedding-dark hover:bg-wedding-dark hover:text-wedding-light animate-fade-in-up mt-8 inline-flex items-center gap-3 bg-transparent px-12 py-5 text-lg font-bold tracking-widest uppercase shadow-sm transition-all delay-200 duration-300 hover:scale-105 active:scale-95"
      >
        {morseMessage.buttonText}
      </button>
    </div>

    <!-- 🦝 MÝVALÍ MINI-ŠIFRA GAME -->
    <div
      class="bg-wedding-light/50 border-wedding-medium/20 hover-card-premium mx-auto mt-16 max-w-md rounded-sm border p-6 shadow-sm"
    >
      <h4
        class="text-wedding-dark mb-3 flex items-center justify-center gap-2 text-sm font-bold tracking-widest uppercase"
      >
        🦝 Mývalí mini-šifra
      </h4>
      <p
        class="text-wedding-dark mb-5 text-xs leading-relaxed font-medium italic opacity-80"
      >
        Dokážeš rozluštit tajný kód pro vstup k mývalům?
      </p>

      <!-- Morse Code to decode -->
      <div
        class="bg-wedding-dark/5 border-wedding-medium/10 mb-5 rounded-sm border py-3.5"
      >
        <p
          class="text-wedding-dark text-lg font-bold tracking-[0.25em] select-all"
        >
          −− / −·−− / ···− / ·− / ·−·· / −−− / ···− / ·
        </p>
      </div>

      {/* Interactive Inputs */}
      <div id="game-controls" class="flex gap-2">
        <input
          type="text"
          id="game-input"
          placeholder="Tvoje odpověď..."
          aria-label="Odpověď na mývalí šifru"
          class="border-wedding-medium/30 focus:border-wedding-dark text-wedding-dark placeholder:text-wedding-medium/40 flex-1 rounded-sm border bg-transparent px-3 py-2 text-sm font-bold tracking-widest uppercase outline-none"
        />
        <button
          id="game-btn"
          class="border-wedding-dark text-wedding-dark hover:bg-wedding-dark hover:text-wedding-light cursor-pointer rounded-sm border px-5 py-2 text-xs font-bold tracking-widest uppercase shadow-sm transition-all duration-300 hover:scale-105 active:scale-95"
        >
          Ověřit
        </button>
      </div>

      <!-- Output Message (Initially Hidden) -->
      <div id="game-success" class="animate-fade-in-up mt-6 hidden text-center">
        <div
          class="morse-line text-wedding-medium/20 mx-auto mb-4 h-[2px] w-24"
        >
        </div>
        <p class="text-wedding-dark mb-1 text-sm font-bold">
          🎉 Kód je správný! Vítej v mývalím doupěti.
        </p>
        <p class="text-wedding-medium mb-4 text-[10px] font-medium italic">
          Tady je tvůj tajný mývalí maskot:
        </p>
        <!-- Cute Text Art Raccoons -->
        <pre
          class="text-wedding-dark bg-wedding-dark/5 border-wedding-medium/15 inline-block rounded-sm border p-3.5 text-left font-mono text-[10px] leading-tight select-all">
         /\_/\ 
      ( (o)Y(o) )
       /  &gt;♥&lt;  \
      /         \
     | |_______| |   ~=~=~
      \____^____/     ~~~
        </pre>
      </div>

      <p
        id="game-error"
        class="mt-3 hidden animate-pulse text-xs font-bold tracking-widest text-red-600 uppercase"
      >
        Kód nesouhlasí, zkus to znovu!
      </p>
    </div>

    <!-- Dark Mode Easter Egg Toggle -->
    <div
      class="mt-20 flex justify-center opacity-30 transition-opacity duration-500 hover:opacity-100"
    >
      <button
        id="theme-toggle"
        class="flex cursor-pointer items-center gap-2 text-xs font-bold tracking-widest uppercase"
        aria-label="Přepnout tmavý režim"
      >
        <span id="theme-toggle-icon" class="text-lg">🌙</span>
        <span class="hidden sm:inline">Režim</span>
      </button>
    </div>
  </div>
</footer>

<script>
  const gameInput = document.getElementById("game-input") as HTMLInputElement;
  const gameBtn = document.getElementById("game-btn");
  const gameSuccess = document.getElementById("game-success");
  const gameError = document.getElementById("game-error");
  const gameControls = document.getElementById("game-controls");

  gameBtn?.addEventListener("click", () => {
    if (!gameInput || !gameSuccess || !gameError || !gameControls) return;

    // Normalize input (ignore case, spaces, diacritics)
    const answer = gameInput.value
      .trim()
      .toUpperCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "") // remove diacritics
      .replace(/\s+/g, ""); // remove spaces

    if (answer === "MYVALOVE") {
      gameError.classList.add("hidden");
      gameControls.classList.add("hidden");
      gameSuccess.classList.remove("hidden");

      // Save puzzle state in localStorage so it stays solved on reload!
      localStorage.setItem("myvalove_puzzle_solved", "true");
    } else {
      gameError.classList.remove("hidden");
      // Hide error after 3 seconds
      setTimeout(() => {
        gameError.classList.add("hidden");
      }, 3000);
    }
  });

  // Listen for Enter key
  gameInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      gameBtn?.click();
    }
  });

  // Check if solved on mount
  if (localStorage.getItem("myvalove_puzzle_solved") === "true") {
    if (gameControls && gameSuccess) {
      gameControls.classList.add("hidden");
      gameSuccess.classList.remove("hidden");
    }
  }

  // Theme Toggle Logic
  const themeToggle = document.getElementById("theme-toggle");
  const themeIcon = document.getElementById("theme-toggle-icon");

  if (themeToggle && themeIcon) {
    const isDark = document.documentElement.classList.contains("dark");
    themeIcon.textContent = isDark ? "☀️" : "🌙";

    themeToggle.addEventListener("click", () => {
      document.documentElement.classList.toggle("dark");
      const currentlyDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", currentlyDark ? "dark" : "light");
      themeIcon.textContent = currentlyDark ? "☀️" : "🌙";
    });
  }
</script>
