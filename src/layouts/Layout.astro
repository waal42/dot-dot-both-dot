---
// src/layouts/Layout.astro
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import { getEntry } from "astro:content";

interface Props {
  title: string;
}

const { title } = Astro.props;
const wedding = await getEntry("wedding", "info");
if (!wedding) {
  throw new Error("Wedding content 'info' not found");
}
const { metaDescription } = wedding.data;
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    id="top"
    class="bg-wedding-light text-wedding-dark font-sans antialiased"
  >
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
