---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import WhenWhere from "../components/WhenWhere.astro";
import Schedule from "../components/Schedule.astro";
import Gifts from "../components/Gifts.astro";
import RsvpForm from "../components/RsvpForm.astro";
import DressCode from "../components/DressCode.astro";
import AboutUs from "../components/AboutUs.astro";

// Import Assets
import fullMotif from "../assets/full-motif.svg";
import heroImageDesktop from "../assets/my-u-more.jpg";
import heroImageMobile from "../assets/my-ve-vytahu.jpg";
import morseMotif from "../assets/morse-motif.svg";
---

<Layout title="Naše Svatba | Hanka & Filip">
  <!-- Hero Cover Section -->
  <section
    class="bg-wedding-dark relative flex h-screen w-full items-center justify-center overflow-hidden"
  >
    <!-- Background Images -->
    <img
      src={heroImageMobile.src}
      alt="Hanka & Filip"
      class="absolute inset-0 h-full w-full object-cover object-center opacity-40 md:hidden"
    />
    <img
      src={heroImageDesktop.src}
      alt="Hanka & Filip"
      class="absolute inset-0 hidden h-full w-full object-cover object-center opacity-40 md:block"
    />

    <div
      class="text-wedding-light relative z-10 flex w-full flex-col items-center px-6 text-center"
    >
      <h2
        class="mb-12 text-xl font-bold tracking-[0.5em] uppercase opacity-80 md:text-2xl"
      >
        Save the date
      </h2>
      <img
        src={fullMotif.src}
        alt="Hanka & Filip Morse Code Motif"
        class="w-full max-w-6xl opacity-70 drop-shadow-[0_4px_20px_rgba(0,0,0,0.4)] invert"
      />
      <p class="mt-12 text-2xl font-bold tracking-tight opacity-90 md:text-4xl">
        15. srpna 2026 • Šlapanice
      </p>
    </div>
    <a
      href="#main-header"
      class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-50 transition-opacity hover:opacity-100"
    >
      <span class="text-wedding-light text-3xl">↓</span>
    </a>
  </section>

  <Header />

  <main class="pb-20">
    <header
      class="flex min-h-[60vh] flex-col items-center justify-center px-6 py-20 text-center"
    >
      <h1
        class="text-wedding-dark mb-8 text-6xl font-bold tracking-tight md:text-8xl"
      >
        Bereme se!
      </h1>
      <p
        class="text-wedding-medium mb-16 text-xl font-medium tracking-tight uppercase opacity-80 md:text-2xl"
      >
        Budeme rádi, když u toho budete s námi.
      </p>

      <a
        href="#rsvp"
        class="morse-border text-wedding-dark border-wedding-dark hover:bg-wedding-dark hover:text-wedding-light mt-8 inline-flex items-center gap-3 bg-transparent px-12 py-5 text-lg font-bold tracking-widest uppercase transition-all duration-300"
      >
        <img
          src={morseMotif.src}
          alt=""
          class="ml-2 h-10 w-auto tracking-widest opacity-60"
        />
        Potvrdit účast
        <img
          src={morseMotif.src}
          alt=""
          class="ml-2 h-10 w-auto tracking-widest opacity-60"
        />
      </a>
    </header>

    <AboutUs />

    <WhenWhere />

    <Schedule />

    <Gifts />

    <RsvpForm />

    <DressCode />
  </main>
</Layout>
